          Enable Lady of the Lake
        </label>
      </div>
    </div>`;
}
function adminForcePhase() { showToast('Force advancing phase...', 'info'); closeAdmin(); advancePhase(); }
function adminReopenVoting() { showToast('Quest voting re-opened.', 'info'); GS.questCards = []; GS.revealedCards = []; closeAdmin(); renderGame(); }
function adminDropToLobby() { closeAdmin(); resetGame(); showView('viewLobby'); renderLobby(); }
function adminTerminateRoom() {
  closeAdmin();
  if (GS.db && GS.roomCode) {
    try { GS.db.ref(`rooms/${GS.roomCode}`).remove(); } catch(e){}
  }
  resetGame(); showView('viewLobby'); renderLobby();
}
function adminToggleLake(val) { GS.demoLake = val; }
async function adminUploadAsset() {
  const fileInput = document.getElementById('adminFileInput');
  const target = document.getElementById('adminCardTarget');
  if (!fileInput || !fileInput.files[0]) { showToast('Select a file first.', 'warn'); return; }
  try {
    const file = fileInput.files[0];
    const reader = new FileReader();
    reader.onload = async (e) => {
      const b64 = e.target.result;
      if (GS.db) {
        try {
          await GS.db.ref(`assets/${target.value.replace('/','_').replace('.png','')}`).set(b64);
          showToast('Asset uploaded & hot-swapped!', 'success');
        } catch(err) { showToast('Firebase upload failed.', 'error'); }
      } else {
        localStorage.setItem(`asset_${target.value}`, b64);
        showToast('Asset cached locally (no Firebase).', 'info');
      }
    };
    reader.readAsDataURL(file);
  } catch(err) { showToast('Upload error: ' + err.message, 'error'); }
}

// ══════════════════════════════════════════════════════
//  ASSET HELPERS
// ══════════════════════════════════════════════════════
function getAssetUrl(path) {
  // Check Firebase-pushed assets first
  const localKey = `asset_${path}`;
  const local = localStorage.getItem(localKey);
  if (local) return local;
  return `./${path}`;
}

function imgOrPlaceholder(path, altText, extraClass = '') {
  const url = getAssetUrl(path);
  return `<img src="${url}" alt="${altText}" class="card-img ${extraClass}"
    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
    style="position:absolute;inset:0;" />
    <div class="card-placeholder" style="display:none;">
      <div style="font-size:2rem;">${getPlaceholderIcon(path)}</div>
      <div style="font-size:10px; margin-top:4px;">${altText}</div>
    </div>`;
}

function getPlaceholderIcon(path) {
  if (path.includes('merlin')) return '🧙';
  if (path.includes('percival')) return '🛡️';
  if (path.includes('assassin')) return '🗡️';
  if (path.includes('morgana')) return '🌑';
  if (path.includes('mordred')) return '💀';
  if (path.includes('oberon')) return '👁️';
  if (path.includes('good')) return '⚔️';
  if (path.includes('evil')) return '🔺';
  if (path.includes('quest_success')) return '✅';
  if (path.includes('quest_fail')) return '❌';
  if (path.includes('vote_approve')) return '✅';
  if (path.includes('vote_reject')) return '❌';
  if (path.includes('leader')) return '👑';
  if (path.includes('lady')) return '🔮';
  if (path.includes('shield')) return '🛡️';
  if (path.includes('tracker')) return '🔢';
  return '🎴';
}

function getRoleCardPath(role) {
  return `cards/${role}.png`;
}

// ══════════════════════════════════════════════════════
//  APP INIT
// ══════════════════════════════════════════════════════
function initApp() {
  const fbOk = initFirebase();

  if (DEMO_MODE_ACTIVE) {
    startDemoMode();
    return;
  }

  if (fbOk && GS.auth) {
    GS.auth.onAuthStateChanged((fbUser) => {
      if (fbUser) {
        GS.user = { uid: fbUser.uid, name: fbUser.displayName || fbUser.email.split('@')[0], email: fbUser.email, isGuest: false };
        GS.isAdmin = (fbUser.email === 'buenavistaaglinaodanny@gmail.com');
        showView('viewLobby');
        renderLobby();
      } else {
        GS.user = null;
        showView('viewAuth');
        renderAuth();
      }
    });
  } else {
    showView('viewAuth');
    renderAuth();
  }
}

