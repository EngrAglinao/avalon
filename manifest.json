//  VIEW SWITCHER
// ══════════════════════════════════════════════════════
const VIEWS = ['viewAuth','viewLobby','viewRoom','viewGame','viewEnd'];
function showView(id) {
  VIEWS.forEach(v => {
    const el = document.getElementById(v);
    if (el) el.style.display = (v === id) ? 'flex' : 'none';
    if (el && v === id) el.style.flexDirection = 'column';
  });
  const nightOvl = document.getElementById('nightOverlay');
  if (nightOvl) nightOvl.style.display = 'none';
  renderSideNav();
}

// ══════════════════════════════════════════════════════
//  SIDE NAV
// ══════════════════════════════════════════════════════
function openNav() {
  document.getElementById('sideNav').classList.add('open');
  document.getElementById('navBackdrop').classList.add('open');
  GS.sideNavOpen = true;
  renderSideNav();
}
function closeNav() {
  document.getElementById('sideNav').classList.remove('open');
  document.getElementById('navBackdrop').classList.remove('open');
  GS.sideNavOpen = false;
}
function renderSideNav() {
  const content = document.getElementById('sideNavContent');
  if (!content) return;
  const signOutBtn = document.getElementById('navSignOutBtn');

  if (GS.phase !== 'SETUP' && GS.phase !== 'LOBBY') {
    // In-game: notepad
    if (signOutBtn) signOutBtn.style.display = 'none';
    let html = `<p class="font-cinzel-base text-yellow-400 text-xs mb-2">📓 Investigation Notepad</p>`;
    GS.players.forEach((p, i) => {
      const flag = GS.notepadFlags[i] || 'neutral';
      const flagColors = { good: 'text-blue-400', evil: 'text-red-400', neutral: 'text-parchment/50' };
      const flagIcons = { good: '🔵', evil: '🔴', neutral: '⬜' };
      html += `<div class="flex items-center gap-2 py-1">
        <button onclick="cycleFlag(${i})" class="text-lg w-7 h-7 flex items-center justify-center rounded-full border border-yellow-800/50">${flagIcons[flag]}</button>
        <span class="${flagColors[flag]} text-sm ${i === GS.myIndex ? 'font-bold' : ''}">${p.name}${i === GS.myIndex ? ' (You)' : ''}</span>
      </div>`;
    });
    html += `<div class="mt-3 pt-3 border-t border-yellow-800/30">
      <p class="text-parchment/40 text-xs">Tap flags to cycle: ⬜ → 🔵 Good → 🔴 Evil → ⬜</p>
    </div>`;
    content.innerHTML = html;
  } else {
    // Lobby / auth
    if (signOutBtn) signOutBtn.style.display = GS.user && !GS.user.isGuest ? 'block' : 'none';
    const userName = GS.user ? GS.user.name : '—';
    const gameCount = parseInt(localStorage.getItem('avalon_games') || '0');
    content.innerHTML = `
      <div class="text-center py-3">
        <div class="w-12 h-12 avatar-ring mx-auto text-lg">${userName.charAt(0).toUpperCase()}</div>
        <p class="font-cinzel-base text-yellow-400 text-sm mt-2">${userName}</p>
        <p class="text-parchment/50 text-xs">${GS.user?.email || 'Guest'}</p>
      </div>
      <div class="border-t border-yellow-800/30 pt-3 space-y-2 text-parchment/70">
        <div class="flex justify-between"><span>Games Played</span><span class="text-yellow-400">${gameCount}</span></div>
      </div>
      <div class="border-t border-yellow-800/30 pt-3">
        <p class="text-parchment/40 text-xs leading-relaxed">The Resistance: Avalon<br/>Mobile PWA v1.0</p>
      </div>`;
  }
}
function cycleFlag(i) {
  const order = ['neutral','good','evil'];
  const cur = GS.notepadFlags[i] || 'neutral';
  GS.notepadFlags[i] = order[(order.indexOf(cur) + 1) % 3];
  renderSideNav();
}

