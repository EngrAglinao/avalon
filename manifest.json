<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>AVALON</title>
  <link rel="manifest" href="./manifest.json" />
  <meta name="theme-color" content="#0b1020" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.12.5/firebase-database-compat.js"></script>
  <style>
    :root {
      color-scheme: dark;
    }
    body {
      background: radial-gradient(circle at top, #1a233f 0%, #090d18 45%, #05070f 100%);
      min-height: 100svh;
    }
    .aura {
      box-shadow: 0 0 0 1px rgba(212, 175, 55, 0.35), 0 12px 40px rgba(0, 0, 0, 0.45);
    }
    .btn-main {
      background: linear-gradient(180deg, #d4af37, #9f7d1a);
      color: #121212;
      font-weight: 800;
      border-radius: 14px;
      min-height: 52px;
      transition: transform 0.2s ease, filter 0.2s ease;
    }
    .btn-main:active {
      transform: scale(0.98);
      filter: brightness(0.95);
    }
    .phase-pulse {
      animation: pulseGlow 2s ease-in-out infinite;
    }
    @keyframes pulseGlow {
      0%, 100% { box-shadow: 0 0 0 rgba(212, 175, 55, 0); }
      50% { box-shadow: 0 0 24px rgba(212, 175, 55, 0.4); }
    }
    .flip {
      transform-style: preserve-3d;
      animation: flipIn 0.7s ease;
    }
    @keyframes flipIn {
      from { transform: rotateY(90deg) scale(0.95); opacity: 0; }
      to { transform: rotateY(0deg) scale(1); opacity: 1; }
    }
  </style>
</head>
<body class="text-slate-100">
  <div id="deviceLock" class="fixed inset-0 z-[80] hidden items-center justify-center bg-black/95 p-8 text-center">
    <div>
      <h1 class="text-2xl font-bold text-amber-300">Handheld Only</h1>
      <p class="mt-3 text-base text-slate-200">This game is only available on handheld mobile devices.</p>
      <p class="mt-2 text-sm text-slate-400">Use a phone or tablet in portrait mode.</p>
    </div>
  </div>

  <div id="installGate" class="fixed inset-0 z-[70] hidden bg-slate-950/95">
    <div class="mx-auto flex min-h-svh w-full max-w-md flex-col items-center justify-center px-6 text-center">
      <p class="text-xs uppercase tracking-[0.35em] text-amber-200">AVALON</p>
      <h2 class="mt-4 text-3xl font-black text-amber-300">Install To Enter</h2>
      <p class="mt-4 text-slate-200">You must install this app on your device before sign-in and gameplay are enabled.</p>
      <button id="installBtn" class="btn-main mt-8 w-full max-w-xs">Install App to Device</button>
      <p id="installHint" class="mt-4 text-sm text-slate-400"></p>
    </div>
  </div>

  <div id="app" class="mx-auto min-h-svh w-full max-w-md px-4 pb-8 pt-4">
    <header class="sticky top-0 z-30 -mx-4 mb-4 border-b border-amber-500/20 bg-slate-950/80 px-4 py-3 backdrop-blur">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-2">
          <div id="brandIcon" class="text-2xl">⚔️</div>
          <div>
            <p id="brandName" class="text-lg font-black tracking-wide text-amber-300">AVALON</p>
            <p id="subline" class="text-[11px] uppercase tracking-[0.2em] text-slate-400">Realtime Court Chamber</p>
          </div>
        </div>
        <button id="openGuideBtn" class="rounded-lg border border-amber-500/40 px-3 py-2 text-xs font-semibold text-amber-200">Instructions</button>
      </div>
    </header>

    <main id="screenRoot" class="space-y-4"></main>
  </div>

  <div id="overlayRoot" class="pointer-events-none fixed inset-0 z-[90]"></div>

  <script>
    const ADMIN_EMAIL = "buenavistaaglinaodanny@gmail.com";
    const STORAGE_KEYS = {
      firebaseConfig: "avalon.firebaseConfig",
      roomId: "avalon.roomId"
    };

    const MANUAL_FIREBASE_CONFIG = {
      apiKey: "",
      authDomain: "",
      databaseURL: "",
      projectId: "",
      storageBucket: "",
      messagingSenderId: "",
      appId: ""
    };

    const DEFAULT_GLOBAL_CONFIG = {
      gameName: "AVALON",
      appIcon: "⚔️",
      rolesEnabled: {
        Merlin: true,
        Percival: true,
        Morgana: true,
        Mordred: true,
        Oberon: true,
        Assassin: true
      }
    };

    const ROLE_META = {
      Merlin: { team: "Good", desc: "Sees Evil players except Mordred." },
      Percival: { team: "Good", desc: "Sees Merlin and Morgana but cannot tell who is Merlin." },
      LoyalServant: { team: "Good", desc: "No special night power. Help Good win 3 quests." },
      Morgana: { team: "Evil", desc: "Appears as Merlin to Percival." },
      Mordred: { team: "Evil", desc: "Hidden from Merlin." },
      Oberon: { team: "Evil", desc: "Unknown to other Evil players and sees none of them." },
      Assassin: { team: "Evil", desc: "May assassinate Merlin if Good wins 3 quests." },
      Minion: { team: "Evil", desc: "Work with Evil team to fail 3 quests." }
    };

    const PLAYER_RULES = {
      5: { good: 3, evil: 2, teamSizes: [2, 3, 2, 3, 3], twoFailsOnQuest: -1 },
      6: { good: 4, evil: 2, teamSizes: [2, 3, 4, 3, 4], twoFailsOnQuest: -1 },
      7: { good: 4, evil: 3, teamSizes: [2, 3, 3, 4, 4], twoFailsOnQuest: 4 },
      8: { good: 5, evil: 3, teamSizes: [3, 4, 4, 5, 5], twoFailsOnQuest: 4 },
      9: { good: 6, evil: 3, teamSizes: [3, 4, 4, 5, 5], twoFailsOnQuest: 4 },
      10: { good: 6, evil: 4, teamSizes: [3, 4, 4, 5, 5], twoFailsOnQuest: 4 }
    };

    const appState = {
      standalone: false,
      deferredPrompt: null,
      firebaseReady: false,
      authReady: false,
      user: null,
      profile: null,
      globalConfig: { ...DEFAULT_GLOBAL_CONFIG },
      networkHash: "unknown",
      roomId: localStorage.getItem(STORAGE_KEYS.roomId) || null,
      room: null,
      availableRooms: [],
      listeners: [],
      toasts: [],
      guideOpen: false,
      showRoleCard: true,
      roleCardFlipped: false,
      qrScannerOpen: false,
      qrStream: null,
      qrScanLoop: null,
      disconnectSeen: {},
      adminDialogPlayer: null
    };

    let auth = null;
    let db = null;

    const el = {
      app: document.getElementById("app"),
      screenRoot: document.getElementById("screenRoot"),
      overlayRoot: document.getElementById("overlayRoot"),
      installGate: document.getElementById("installGate"),
      installBtn: document.getElementById("installBtn"),
      installHint: document.getElementById("installHint"),
      deviceLock: document.getElementById("deviceLock"),
      brandName: document.getElementById("brandName"),
      brandIcon: document.getElementById("brandIcon"),
      openGuideBtn: document.getElementById("openGuideBtn")
    };

    function uid() {
      return appState.user ? appState.user.uid : null;
    }

    function isAdmin() {
      return appState.user && appState.user.email === ADMIN_EMAIL;
    }

    function isHost() {
      return appState.room && appState.room.hostUid === uid();
    }

    function isStandalone() {
      return window.matchMedia("(display-mode: standalone)").matches || window.navigator.standalone === true;
    }

    function isMobileDevice() {
      const ua = navigator.userAgent || "";
      const mobileUa = /Android|iPhone|iPad|iPod|Mobile|Tablet/i.test(ua);
      const coarse = window.matchMedia("(pointer: coarse)").matches;
      return mobileUa || coarse;
    }

    function checkDeviceLock() {
      const portrait = window.innerHeight >= window.innerWidth;
      const handheld = isMobileDevice() && Math.min(window.innerWidth, window.innerHeight) <= 1024;
      const blocked = !portrait || !handheld;
      el.deviceLock.classList.toggle("hidden", !blocked);
      el.deviceLock.classList.toggle("flex", blocked);
      return blocked;
    }

    function showInstallGate(message) {
      el.installGate.classList.remove("hidden");
      el.installHint.textContent = message || "";
    }

    function hideInstallGate() {
      el.installGate.classList.add("hidden");
      el.installHint.textContent = "";
    }

    function sanitizeConfig(config) {
      const keys = ["apiKey", "authDomain", "databaseURL", "projectId", "storageBucket", "messagingSenderId", "appId"];
      const cleaned = {};
      for (const key of keys) cleaned[key] = (config[key] || "").trim();
      const valid = keys.every((k) => cleaned[k]);
      return valid ? cleaned : null;
    }

    function toast(message) {
      const id = crypto.randomUUID();
      appState.toasts.push({ id, message });
      renderOverlays();
      setTimeout(() => {
        appState.toasts = appState.toasts.filter((t) => t.id !== id);
        renderOverlays();
      }, 3000);
    }

    function clearListeners() {
      appState.listeners.forEach((fn) => fn());
      appState.listeners = [];
    }

    async function sha1(text) {
      const buf = await crypto.subtle.digest("SHA-1", new TextEncoder().encode(text));
      return Array.from(new Uint8Array(buf)).map((b) => b.toString(16).padStart(2, "0")).join("").slice(0, 16);
    }

    async function detectLocalIp() {
      return new Promise((resolve) => {
        const RTCPeer = window.RTCPeerConnection || window.webkitRTCPeerConnection;
        if (!RTCPeer) return resolve(null);
        const pc = new RTCPeer({ iceServers: [] });
        const timeout = setTimeout(() => {
          pc.close();
          resolve(null);
        }, 1300);
        pc.createDataChannel("x");
        pc.createOffer().then((offer) => pc.setLocalDescription(offer)).catch(() => resolve(null));
        pc.onicecandidate = (ev) => {
          if (!ev || !ev.candidate || !ev.candidate.candidate) return;
          const match = ev.candidate.candidate.match(/(\d+\.\d+\.\d+\.\d+)/);
          if (!match) return;
          const ip = match[1];
          if (/^(10\.|192\.168\.|172\.(1[6-9]|2\d|3[0-1])\.)/.test(ip)) {
            clearTimeout(timeout);
            pc.close();
            resolve(ip);
          }
        };
      });
    }

    async function deriveNetworkHash() {
      let source = "unknown";
      const localIp = await detectLocalIp();
      if (localIp) {
        const parts = localIp.split(".");
        source = `${parts[0]}.${parts[1]}.${parts[2]}.x`;
      } else {
        try {
          const res = await fetch("https://api64.ipify.org?format=json", { cache: "no-store" });
          const data = await res.json();
          source = data.ip || "unknown";
        } catch (_err) {
          source = `${navigator.userAgent}|${Intl.DateTimeFormat().resolvedOptions().timeZone || "tz"}`;
        }
      }
      appState.networkHash = await sha1(source);
    }

    async function initFirebase() {
      const manual = sanitizeConfig(MANUAL_FIREBASE_CONFIG);
      const stored = sanitizeConfig(JSON.parse(localStorage.getItem(STORAGE_KEYS.firebaseConfig) || "{}"));
      const config = manual || stored;
      if (!config) return false;

      if (!firebase.apps.length) firebase.initializeApp(config);
      auth = firebase.auth();
      db = firebase.database();
      appState.firebaseReady = true;
      return true;
    }

    function saveFirebaseConfigFromForm(formData) {
      const cfg = sanitizeConfig(Object.fromEntries(formData.entries()));
      if (!cfg) {
        toast("Fill all Firebase config fields.");
        return;
      }
      localStorage.setItem(STORAGE_KEYS.firebaseConfig, JSON.stringify(cfg));
      window.location.reload();
    }

    function bindPresence(roomId) {
      const myUid = uid();
      if (!myUid || !roomId) return;
      const connRef = db.ref(".info/connected");
      const presenceRef = db.ref(`rooms/${roomId}/players/${myUid}`);
      const cb = connRef.on("value", (snap) => {
        if (!snap.val()) return;
        presenceRef.onDisconnect().update({ connected: false, lastSeen: firebase.database.ServerValue.TIMESTAMP });
        presenceRef.update({ connected: true, lastSeen: firebase.database.ServerValue.TIMESTAMP });
      });
      appState.listeners.push(() => connRef.off("value", cb));
    }

    function setupAuthListener() {
      auth.onAuthStateChanged(async (user) => {
        clearListeners();
        appState.user = user || null;
        if (!user) {
          appState.profile = null;
          appState.room = null;
          appState.roomId = null;
          localStorage.removeItem(STORAGE_KEYS.roomId);
          render();
          return;
        }
        await ensureProfile(user);
        attachGlobalConfigListener();
        await deriveNetworkHash();
        let joinedFromQuery = false;
        const roomCodeFromQuery = new URLSearchParams(location.search).get("room");
        if (roomCodeFromQuery && !appState.roomId) {
          await joinRoomByCode(roomCodeFromQuery);
          joinedFromQuery = true;
        }
        if (appState.roomId && !joinedFromQuery) attachRoomListener(appState.roomId);
        attachAvailableRoomsListener();
        render();
      });
    }

    async function ensureProfile(user) {
      const profileRef = db.ref(`profiles/${user.uid}`);
      const snap = await profileRef.once("value");
      const existing = snap.val();
      const base = {
        nickname: user.displayName || "Knight",
        photoURL: user.photoURL || "",
        email: user.email,
        updatedAt: firebase.database.ServerValue.TIMESTAMP
      };
      if (!existing) {
        await profileRef.set({ ...base, createdAt: firebase.database.ServerValue.TIMESTAMP, history: {} });
        appState.profile = { ...base, history: {} };
      } else {
        appState.profile = existing;
      }
    }

    function attachGlobalConfigListener() {
      const ref = db.ref("appConfig/global");
      const cb = ref.on("value", async (snap) => {
        const cfg = snap.val();
        if (!cfg && isAdmin()) {
          await ref.set(DEFAULT_GLOBAL_CONFIG);
          return;
        }
        appState.globalConfig = { ...DEFAULT_GLOBAL_CONFIG, ...(cfg || {}) };
        el.brandName.textContent = appState.globalConfig.gameName || "AVALON";
        el.brandIcon.textContent = appState.globalConfig.appIcon || "⚔️";
        render();
      });
      appState.listeners.push(() => ref.off("value", cb));
    }

    function attachAvailableRoomsListener() {
      if (!db || !appState.user) return;
      const query = db.ref("rooms").orderByChild("networkHash").equalTo(appState.networkHash);
      const cb = query.on("value", (snap) => {
        const all = snap.val() || {};
        appState.availableRooms = Object.entries(all)
          .map(([id, room]) => ({ id, ...room }))
          .filter((r) => r.status === "lobby")
          .sort((a, b) => (b.updatedAt || 0) - (a.updatedAt || 0));
        render();
      });
      appState.listeners.push(() => query.off("value", cb));
    }

    function attachRoomListener(roomId) {
      if (!roomId || !db) return;
      appState.roomId = roomId;
      localStorage.setItem(STORAGE_KEYS.roomId, roomId);
      const ref = db.ref(`rooms/${roomId}`);
      const cb = ref.on("value", (snap) => {
        const room = snap.val();
        if (!room) {
          toast("Room ended.");
          appState.room = null;
          appState.roomId = null;
          localStorage.removeItem(STORAGE_KEYS.roomId);
          render();
          return;
        }
        appState.room = room;
        detectDisconnects(room.players || {});
        if (!room.players || !room.players[uid()]) {
          appState.room = null;
          appState.roomId = null;
          localStorage.removeItem(STORAGE_KEYS.roomId);
        }
        maybeArchiveHistory(roomId, room);
        render();
      });
      appState.listeners.push(() => ref.off("value", cb));
      bindPresence(roomId);
    }

    function detectDisconnects(players) {
      for (const [pid, p] of Object.entries(players)) {
        const prev = appState.disconnectSeen[pid];
        const now = p.connected !== false;
        if (prev !== undefined && prev === true && now === false) {
          toast(`${p.nickname || "Player"} has disconnected.`);
          if (isAdmin() && appState.room && appState.room.phase !== "lobby" && appState.room.phase !== "end") {
            appState.adminDialogPlayer = p.nickname || "Player";
          }
        }
        appState.disconnectSeen[pid] = now;
      }
    }

    async function maybeArchiveHistory(roomId, room) {
      if (room.phase !== "end" || room.historyArchived) return;
      if (!isHost()) return;
      const updates = {};
      const players = room.players || {};
      const roles = room.roleAssignments || {};
      for (const [pid, p] of Object.entries(players)) {
        updates[`profiles/${pid}/history/${roomId}`] = {
          roomCode: room.code,
          result: room.winner || "Unknown",
          role: roles[pid] || "Unknown",
          at: firebase.database.ServerValue.TIMESTAMP,
          nickname: p.nickname || "Knight"
        };
      }
      updates[`rooms/${roomId}/historyArchived`] = true;
      await db.ref().update(updates);
    }

    async function signInGoogle() {
      try {
        const provider = new firebase.auth.GoogleAuthProvider();
        await auth.signInWithPopup(provider);
      } catch (_err) {
        toast("Google sign-in popup blocked. Try again.");
      }
    }

    async function signOut() {
      await auth.signOut();
      clearListeners();
      closeQrScanner();
      appState.room = null;
      appState.roomId = null;
      localStorage.removeItem(STORAGE_KEYS.roomId);
      render();
    }

    function randomCode() {
      return Math.random().toString(36).slice(2, 8).toUpperCase();
    }

    async function createRoom() {
      const myUid = uid();
      const prof = appState.profile;
      if (!myUid || !prof) return;
      const roomRef = db.ref("rooms").push();
      const code = randomCode();
      const roomData = {
        code,
        hostUid: myUid,
        hostEmail: appState.user.email || "",
        networkHash: appState.networkHash,
        status: "lobby",
        phase: "lobby",
        round: 1,
        questIndex: 0,
        goodScore: 0,
        evilScore: 0,
        rejectCount: 0,
        questResults: [null, null, null, null, null],
        leaderIndex: 0,
        teamNomination: [],
        votes: { teamApproval: {}, quest: {} },
        selectedRoles: { ...(appState.globalConfig.rolesEnabled || DEFAULT_GLOBAL_CONFIG.rolesEnabled) },
        players: {
          [myUid]: {
            uid: myUid,
            email: appState.user.email,
            nickname: prof.nickname,
            photoURL: prof.photoURL,
            isHost: true,
            connected: true,
            joinedAt: firebase.database.ServerValue.TIMESTAMP,
            lastSeen: firebase.database.ServerValue.TIMESTAMP
          }
        },
        createdAt: firebase.database.ServerValue.TIMESTAMP,
        updatedAt: firebase.database.ServerValue.TIMESTAMP
      };
      await roomRef.set(roomData);
      attachRoomListener(roomRef.key);
    }

    async function joinRoomByCode(codeRaw) {
      const code = (codeRaw || "").trim().toUpperCase();
      if (!code) return;
      const snap = await db.ref("rooms").orderByChild("code").equalTo(code).once("value");
      const rooms = snap.val() || {};
      const found = Object.entries(rooms)[0];
      if (!found) return toast("Room code not found.");
      const [roomId, room] = found;
      if (room.phase === "end") return toast("This room has already ended.");
      const playerCount = Object.keys(room.players || {}).length;
      if (playerCount >= 10 && !(room.players || {})[uid()]) return toast("Room is full.");
      await db.ref(`rooms/${roomId}/players/${uid()}`).update({
        uid: uid(),
        email: appState.user.email,
        nickname: appState.profile.nickname,
        photoURL: appState.profile.photoURL,
        isHost: false,
        connected: true,
        joinedAt: firebase.database.ServerValue.TIMESTAMP,
        lastSeen: firebase.database.ServerValue.TIMESTAMP
      });
      await db.ref(`rooms/${roomId}/updatedAt`).set(firebase.database.ServerValue.TIMESTAMP);
      attachRoomListener(roomId);
    }

    async function leaveRoom() {
      if (!appState.roomId) return;
      const roomId = appState.roomId;
      await db.ref(`rooms/${roomId}/players/${uid()}`).remove();
      appState.room = null;
      appState.roomId = null;
      localStorage.removeItem(STORAGE_KEYS.roomId);
      render();
    }

    function shuffle(arr) {
      const a = arr.slice();
      for (let i = a.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [a[i], a[j]] = [a[j], a[i]];
      }
      return a;
    }

    function buildRolePool(playerCount, selectedRoles) {
      const rules = PLAYER_RULES[playerCount];
      const goodTarget = rules.good;
      const evilTarget = rules.evil;
      const evil = [];
      const good = [];

      if (selectedRoles.Assassin && evil.length < evilTarget) evil.push("Assassin");
      if (selectedRoles.Morgana && evil.length < evilTarget) evil.push("Morgana");
      if (selectedRoles.Mordred && evil.length < evilTarget) evil.push("Mordred");
      if (selectedRoles.Oberon && evil.length < evilTarget) evil.push("Oberon");
      while (evil.length < evilTarget) evil.push("Minion");

      if (selectedRoles.Merlin && good.length < goodTarget) good.push("Merlin");
      if (selectedRoles.Percival && good.length < goodTarget) good.push("Percival");
      while (good.length < goodTarget) good.push("LoyalServant");

      return shuffle([...good, ...evil]);
    }

    function getRoleIntel(role, roleByUid, players) {
      const namesByUid = {};
      for (const [pid, p] of Object.entries(players || {})) namesByUid[pid] = p.nickname || "Knight";
      const entries = Object.entries(roleByUid || {});
      const evilUids = entries.filter(([, r]) => ["Morgana", "Mordred", "Oberon", "Assassin", "Minion"].includes(r)).map(([id]) => id);
      const intel = [];

      if (role === "Merlin") {
        entries.forEach(([id, r]) => {
          if (["Morgana", "Assassin", "Minion", "Oberon"].includes(r)) intel.push(namesByUid[id]);
        });
      }
      if (role === "Percival") {
        entries.forEach(([id, r]) => {
          if (["Merlin", "Morgana"].includes(r)) intel.push(namesByUid[id]);
        });
      }
      if (["Morgana", "Mordred", "Assassin", "Minion"].includes(role)) {
        evilUids.forEach((id) => {
          const r = roleByUid[id];
          if (id !== uid() && r !== "Oberon") intel.push(namesByUid[id]);
        });
      }
      if (role === "Oberon") {
        return "You are hidden from other Evil players and you see no allies.";
      }
      if (!intel.length) return "No special visibility information.";
      return `You can identify: ${intel.join(", ")}.`;
    }

    async function startGame() {
      if (!appState.room || !isHost()) return;
      const players = Object.entries(appState.room.players || {});
      const count = players.length;
      if (count < 5 || count > 10) return toast("Avalon requires 5 to 10 players.");
      const roles = buildRolePool(count, appState.room.selectedRoles || {});
      const shuffledPlayers = shuffle(players.map(([pid]) => pid));
      const assign = {};
      shuffledPlayers.forEach((pid, i) => { assign[pid] = roles[i]; });
      await db.ref(`rooms/${appState.roomId}`).update({
        status: "in_game",
        phase: "night",
        roleAssignments: assign,
        leaderIndex: 0,
        round: 1,
        questIndex: 0,
        goodScore: 0,
        evilScore: 0,
        rejectCount: 0,
        votes: { teamApproval: {}, quest: {} },
        teamNomination: [],
        questResults: [null, null, null, null, null],
        updatedAt: firebase.database.ServerValue.TIMESTAMP
      });
    }

    function currentLeaderUid(room) {
      const ids = Object.keys(room.players || {});
      if (!ids.length) return null;
      return ids[room.leaderIndex % ids.length];
    }

    function missionSize(room) {
      const count = Object.keys(room.players || {}).length;
      const rules = PLAYER_RULES[count] || PLAYER_RULES[5];
      return rules.teamSizes[room.questIndex || 0] || 2;
    }

    async function submitNomination(selectedUids) {
      if (!appState.room) return;
      if (selectedUids.length !== missionSize(appState.room)) return toast("Team size mismatch.");
      await db.ref(`rooms/${appState.roomId}`).update({
        teamNomination: selectedUids,
        phase: "team_vote",
        votes: { teamApproval: {}, quest: {} },
        updatedAt: firebase.database.ServerValue.TIMESTAMP
      });
    }

    async function castTeamVote(value) {
      await db.ref(`rooms/${appState.roomId}/votes/teamApproval/${uid()}`).set(value);
      await db.ref(`rooms/${appState.roomId}/players/${uid()}/lastSeen`).set(firebase.database.ServerValue.TIMESTAMP);
    }

    async function castQuestVote(value) {
      const myRole = (appState.room.roleAssignments || {})[uid()];
      if (["Merlin", "Percival", "LoyalServant"].includes(myRole) && value === "fail") return toast("Good roles cannot play Fail.");
      await db.ref(`rooms/${appState.roomId}/votes/quest/${uid()}`).set(value);
      await db.ref(`rooms/${appState.roomId}/players/${uid()}/lastSeen`).set(firebase.database.ServerValue.TIMESTAMP);
    }

    async function hostContinue() {
      if (!appState.room || !isHost()) return;
      const room = appState.room;
      const players = Object.keys(room.players || {});
      const rules = PLAYER_RULES[players.length];
      if (!rules) return;

      if (room.phase === "night") {
        return db.ref(`rooms/${appState.roomId}`).update({ phase: "day", updatedAt: firebase.database.ServerValue.TIMESTAMP });
      }

      if (room.phase === "team_vote") {
        const votes = room.votes && room.votes.teamApproval ? room.votes.teamApproval : {};
        if (Object.keys(votes).length < players.length) return toast("Waiting for all votes.");
        const approvals = Object.values(votes).filter((v) => v === "approve").length;
        if (approvals > players.length / 2) {
          return db.ref(`rooms/${appState.roomId}`).update({ phase: "quest_vote", votes: { teamApproval: votes, quest: {} } });
        }
        const nextReject = (room.rejectCount || 0) + 1;
        if (nextReject >= 5) {
          return db.ref(`rooms/${appState.roomId}`).update({ phase: "end", status: "ended", winner: "Evil", winReason: "Five consecutive rejected teams." });
        }
        return db.ref(`rooms/${appState.roomId}`).update({
          phase: "day",
          rejectCount: nextReject,
          leaderIndex: ((room.leaderIndex || 0) + 1) % players.length,
          votes: { teamApproval: {}, quest: {} },
          teamNomination: [],
          updatedAt: firebase.database.ServerValue.TIMESTAMP
        });
      }

      if (room.phase === "quest_vote") {
        const team = room.teamNomination || [];
        const questVotes = room.votes && room.votes.quest ? room.votes.quest : {};
        if (Object.keys(questVotes).length < team.length) return toast("Waiting for mission team votes.");
        const fails = Object.values(questVotes).filter((v) => v === "fail").length;
        const questNumber = (room.questIndex || 0) + 1;
        const requiresTwoFails = rules.twoFailsOnQuest === questNumber;
        const missionFailed = requiresTwoFails ? fails >= 2 : fails >= 1;
        const questResults = (room.questResults || [null, null, null, null, null]).slice();
        questResults[room.questIndex || 0] = missionFailed ? "Fail" : "Success";
        const goodScore = (room.goodScore || 0) + (missionFailed ? 0 : 1);
        const evilScore = (room.evilScore || 0) + (missionFailed ? 1 : 0);

        if (goodScore >= 3) {
          const hasAssassin = Object.values(room.roleAssignments || {}).includes("Assassin");
          if (hasAssassin) {
            return db.ref(`rooms/${appState.roomId}`).update({
              phase: "assassination",
              goodScore,
              evilScore,
              questResults,
              votes: { teamApproval: {}, quest: {} },
              updatedAt: firebase.database.ServerValue.TIMESTAMP
            });
          }
          return db.ref(`rooms/${appState.roomId}`).update({
            phase: "end",
            status: "ended",
            winner: "Good",
            winReason: "Good completed 3 successful quests.",
            goodScore,
            evilScore,
            questResults,
            updatedAt: firebase.database.ServerValue.TIMESTAMP
          });
        }

        if (evilScore >= 3) {
          return db.ref(`rooms/${appState.roomId}`).update({
            phase: "end",
            status: "ended",
            winner: "Evil",
            winReason: "Evil failed 3 quests.",
            goodScore,
            evilScore,
            questResults,
            updatedAt: firebase.database.ServerValue.TIMESTAMP
          });
        }

        return db.ref(`rooms/${appState.roomId}`).update({
          phase: "day",
          round: (room.round || 1) + 1,
          questIndex: (room.questIndex || 0) + 1,
          goodScore,
          evilScore,
          questResults,
          rejectCount: 0,
          teamNomination: [],
          votes: { teamApproval: {}, quest: {} },
          leaderIndex: ((room.leaderIndex || 0) + 1) % players.length,
          updatedAt: firebase.database.ServerValue.TIMESTAMP
        });
      }
    }

    async function performAssassination(targetUid) {
      const roles = appState.room.roleAssignments || {};
      const targetRole = roles[targetUid];
      const winner = targetRole === "Merlin" ? "Evil" : "Good";
      const reason = targetRole === "Merlin" ? "Assassin eliminated Merlin." : "Assassin failed to find Merlin.";
      await db.ref(`rooms/${appState.roomId}`).update({
        phase: "end",
        status: "ended",
        winner,
        winReason: reason,
        assassinationTarget: targetUid,
        updatedAt: firebase.database.ServerValue.TIMESTAMP
      });
    }

