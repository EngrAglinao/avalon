      `;
    }

    function renderNightPhase(room) {
      const myRole = roleOfMe();
      const intel = getRoleIntel(myRole, room.roleAssignments || {}, room.players || {});
      return `
        ${renderQuestBoard(room)}
        <section class="aura rounded-2xl border border-slate-700 bg-slate-900/75 p-4">
          <div class="flex items-center justify-between">
            <h3 class="text-lg font-bold text-amber-200">Role Peek</h3>
            <button id="toggleRoleBtn" class="rounded-lg border border-slate-600 px-3 py-2 text-xs">${appState.showRoleCard ? "Hide" : "Show"}</button>
          </div>
          ${appState.showRoleCard ? `
            <div class="flip mt-3 rounded-xl border border-amber-500/30 bg-gradient-to-b from-slate-800 to-slate-950 p-4">
              <p class="text-xs uppercase tracking-[0.2em] text-slate-400">Your Role</p>
              <p class="mt-1 text-2xl font-black text-amber-300">${myRole || "Unknown"}</p>
              <p class="mt-2 text-sm text-slate-200">${ROLE_META[myRole] ? ROLE_META[myRole].desc : ""}</p>
              <p class="mt-2 text-xs text-slate-300">${intel}</p>
            </div>
          ` : `<p class="mt-3 text-sm text-slate-400">Role card hidden.</p>`}
          ${isHost() ? `<button id="hostContinueBtn" class="btn-main mt-4 w-full">Host Continue</button>` : `<p class="mt-3 text-sm text-slate-400">Waiting for host...</p>`}
        </section>
      `;
    }

    function renderDayPhase(room) {
      const leaderUid = currentLeaderUid(room);
      const iAmLeader = leaderUid === uid();
      const size = missionSize(room);
      const players = Object.values(room.players || {});
      return `
        ${renderQuestBoard(room)}
        <section class="aura rounded-2xl border border-slate-700 bg-slate-900/75 p-4">
          <p class="text-sm text-slate-300">Nominate <span class="font-bold text-amber-300">${size}</span> players for the next quest.</p>
          ${iAmLeader ? `
            <form id="nominationForm" class="mt-3 grid gap-2">
              ${players.map((p) => `<label class="flex items-center justify-between rounded-lg border border-slate-700 px-3 py-2"><span>${p.nickname}</span><input type="checkbox" name="team" value="${p.uid}"></label>`).join("")}
              <button class="btn-main mt-2 w-full">Submit Team</button>
            </form>
          ` : `<p class="mt-3 rounded-lg border border-slate-700 p-3 text-sm">Leader ${room.players[leaderUid] ? room.players[leaderUid].nickname : "-"} is nominating the team.</p>`}
          ${isHost() ? `<button id="hostContinueBtn" class="mt-3 w-full rounded-xl border border-slate-600 py-3 text-sm">Host Continue</button>` : ""}
        </section>
      `;
    }

    function renderTeamVotePhase(room) {
      const votes = room.votes && room.votes.teamApproval ? room.votes.teamApproval : {};
      const players = Object.values(room.players || {});
      const voted = !!votes[uid()];
      return `
        ${renderQuestBoard(room)}
        <section class="aura rounded-2xl border border-slate-700 bg-slate-900/75 p-4">
          <h3 class="text-lg font-bold text-amber-200">Team Approval Vote</h3>
          <p class="mt-2 text-sm">Team: ${(room.teamNomination || []).map((id) => room.players[id] ? room.players[id].nickname : "?").join(", ")}</p>
          ${voted ? `<p class="mt-3 text-sm text-emerald-300">Vote submitted.</p>` : `
            <div class="mt-3 grid grid-cols-2 gap-2">
              <button id="approveBtn" class="rounded-xl border border-emerald-500/50 bg-emerald-900/30 py-3 font-bold">Approve</button>
              <button id="rejectBtn" class="rounded-xl border border-rose-500/50 bg-rose-900/30 py-3 font-bold">Reject</button>
            </div>
          `}
          <div class="mt-3 rounded-lg border border-slate-700 p-3 text-xs">
            <p class="font-bold uppercase tracking-[0.12em] text-slate-400">Vote Status Indicator</p>
            <div class="mt-2 grid gap-1">
              ${players.map((p) => `<div class="flex justify-between"><span>${p.nickname}</span><span class="${votes[p.uid] ? "text-emerald-300" : "text-slate-500"}">${votes[p.uid] ? "Voted" : "Waiting"}</span></div>`).join("")}
            </div>
          </div>
          ${isHost() ? `<button id="hostContinueBtn" class="btn-main mt-4 w-full">Host Continue</button>` : ""}
        </section>
      `;
    }

    function renderQuestVotePhase(room) {
      const team = room.teamNomination || [];
      const onTeam = team.includes(uid());
      const myRole = roleOfMe();
      const votes = room.votes && room.votes.quest ? room.votes.quest : {};
      return `
        ${renderQuestBoard(room)}
        <section class="aura rounded-2xl border border-slate-700 bg-slate-900/75 p-4">
          <h3 class="text-lg font-bold text-amber-200">Quest Vote</h3>
          <p class="mt-2 text-sm text-slate-300">Mission team: ${team.map((id) => room.players[id] ? room.players[id].nickname : "?").join(", ")}</p>
          ${onTeam ? (votes[uid()] ? `<p class="mt-3 text-sm text-emerald-300">Vote submitted.</p>` : `
            <div class="mt-3 grid grid-cols-2 gap-2">
              <button id="successBtn" class="rounded-xl border border-emerald-500/50 bg-emerald-900/30 py-3 font-bold">Success</button>
              <button id="failBtn" class="rounded-xl border border-rose-500/50 bg-rose-900/30 py-3 font-bold ${["Merlin","Percival","LoyalServant"].includes(myRole) ? "opacity-40" : ""}" ${["Merlin","Percival","LoyalServant"].includes(myRole) ? "disabled" : ""}>Fail</button>
            </div>
          `) : `<p class="mt-3 rounded-lg border border-slate-700 p-3 text-sm text-slate-400">You are not on this mission.</p>`}
          <div class="mt-3 rounded-lg border border-slate-700 p-3 text-xs">
            <p class="font-bold uppercase tracking-[0.12em] text-slate-400">Vote Status Indicator</p>
            <div class="mt-2 grid gap-1">
              ${team.map((pid) => `<div class="flex justify-between"><span>${room.players[pid] ? room.players[pid].nickname : "?"}</span><span class="${votes[pid] ? "text-emerald-300" : "text-slate-500"}">${votes[pid] ? "Voted" : "Waiting"}</span></div>`).join("")}
            </div>
          </div>
          ${isHost() ? `<button id="hostContinueBtn" class="btn-main mt-4 w-full">Host Continue</button>` : ""}
        </section>
      `;
    }

    function renderAssassinationPhase(room) {
      const entries = Object.entries(room.roleAssignments || {});
      const assassinUid = entries.find(([, role]) => role === "Assassin");
      const iAmAssassin = assassinUid && assassinUid[0] === uid();
      const targets = Object.values(room.players || {});
      return `
        ${renderQuestBoard(room)}
        <section class="aura rounded-2xl border border-rose-500/40 bg-slate-900/75 p-4">
          <h3 class="text-lg font-bold text-rose-300">Assassination Phase</h3>
          <p class="mt-2 text-sm text-slate-300">Good has 3 successful quests. Assassin must identify Merlin.</p>
          ${iAmAssassin ? `
            <form id="assassinForm" class="mt-3 grid gap-2">
              ${targets.map((p) => `<label class="flex items-center justify-between rounded-lg border border-slate-700 px-3 py-2"><span>${p.nickname}</span><input type="radio" name="target" value="${p.uid}" required></label>`).join("")}
              <button class="btn-main mt-2 w-full">Confirm Assassination</button>
            </form>
          ` : `<p class="mt-3 rounded-lg border border-slate-700 p-3 text-sm">Waiting for the Assassin to choose a target.</p>`}
        </section>
      `;
    }

    function renderEndPhase(room) {
      const reveal = Object.entries(room.roleAssignments || {}).map(([pid, role]) => {
        const p = room.players[pid];
        return `<div class="flex justify-between rounded-lg border border-slate-700 px-3 py-2 text-sm"><span>${p ? p.nickname : pid}</span><span class="font-semibold text-amber-200">${role}</span></div>`;
      }).join("");
      return `
        ${renderQuestBoard(room)}
        <section class="aura rounded-2xl border border-amber-500/40 bg-slate-900/75 p-4">
          <h3 class="text-2xl font-black text-amber-300">${room.winner || "Game Over"}</h3>
          <p class="mt-2 text-sm text-slate-300">${room.winReason || "Session complete."}</p>
          <div class="mt-3 grid gap-2">${reveal}</div>
          ${isHost() ? `<button id="resetLobbyBtn" class="btn-main mt-4 w-full">Return To Lobby</button>` : `<p class="mt-4 text-sm text-slate-400">Waiting for host to reset.</p>`}
        </section>
      `;
    }

    function renderGame(room) {
      let html = "";
      if (room.phase === "night") html = renderNightPhase(room);
      if (room.phase === "day") html = renderDayPhase(room);
      if (room.phase === "team_vote") html = renderTeamVotePhase(room);
      if (room.phase === "quest_vote") html = renderQuestVotePhase(room);
      if (room.phase === "assassination") html = renderAssassinationPhase(room);
      if (room.phase === "end") html = renderEndPhase(room);

      el.screenRoot.innerHTML = html;

      const hostBtn = document.getElementById("hostContinueBtn");
      if (hostBtn) hostBtn.addEventListener("click", hostContinue);

      const toggleRoleBtn = document.getElementById("toggleRoleBtn");
      if (toggleRoleBtn) toggleRoleBtn.addEventListener("click", () => {
        appState.showRoleCard = !appState.showRoleCard;
        renderGame(room);
      });

      const nominationForm = document.getElementById("nominationForm");
      if (nominationForm) {
        nominationForm.addEventListener("submit", (e) => {
          e.preventDefault();
          const picks = Array.from(nominationForm.querySelectorAll("input[name='team']:checked")).map((i) => i.value);
          submitNomination(picks);
        });
      }

      const approveBtn = document.getElementById("approveBtn");
      const rejectBtn = document.getElementById("rejectBtn");
      if (approveBtn) approveBtn.addEventListener("click", () => castTeamVote("approve"));
      if (rejectBtn) rejectBtn.addEventListener("click", () => castTeamVote("reject"));

      const successBtn = document.getElementById("successBtn");
      const failBtn = document.getElementById("failBtn");
      if (successBtn) successBtn.addEventListener("click", () => castQuestVote("success"));
      if (failBtn) failBtn.addEventListener("click", () => castQuestVote("fail"));

      const assassinForm = document.getElementById("assassinForm");
      if (assassinForm) {
        assassinForm.addEventListener("submit", (e) => {
          e.preventDefault();
          const targetUid = new FormData(assassinForm).get("target");
          if (targetUid) performAssassination(targetUid);
        });
      }

      const resetLobbyBtn = document.getElementById("resetLobbyBtn");
      if (resetLobbyBtn) resetLobbyBtn.addEventListener("click", adminResetLobby);
    }

    function renderOverlays() {
      const guide = appState.guideOpen ? (() => {
        const myRole = roleOfMe();
        const roleText = myRole ? `${myRole}: ${ROLE_META[myRole].desc}` : "Join a game to see role-specific guidance.";
        return `
          <div class="pointer-events-auto fixed inset-0 bg-black/75 p-4">
            <div class="mx-auto mt-8 w-full max-w-md rounded-2xl border border-amber-500/30 bg-slate-900 p-4">
              <div class="flex items-center justify-between">
                <h3 class="text-lg font-bold text-amber-200">Instructions</h3>
                <button id="closeGuideBtn" class="rounded-lg border border-slate-600 px-2 py-1 text-xs">Close</button>
              </div>
              <p class="mt-3 text-sm text-slate-200">Phases: Night role reveal -> Day team nomination -> Team approval vote -> Quest vote -> Assassination (if Good reaches 3) -> End screen.</p>
              <p class="mt-2 text-sm text-slate-200">Team vote needs majority approve. Five consecutive rejected teams gives Evil a win.</p>
              <p class="mt-2 text-sm text-slate-200">Quest team members vote secretly. Any Fail fails the quest, except Quest 4 requires two Fails in 7+ player games.</p>
              <div class="mt-3 rounded-lg border border-slate-700 p-3 text-sm">
                <p class="text-xs uppercase tracking-[0.15em] text-slate-400">Your Role Context</p>
                <p class="mt-1 text-amber-200">${roleText}</p>
              </div>
            </div>
          </div>
        `;
      })() : "";

      const adminDialog = appState.adminDialogPlayer ? `
        <div class="pointer-events-auto fixed inset-0 bg-black/70 p-4">
          <div class="mx-auto mt-24 w-full max-w-md rounded-2xl border border-rose-500/40 bg-slate-900 p-4">
            <h3 class="text-lg font-bold text-rose-300">Admin Disconnect Control</h3>
            <p class="mt-2 text-sm text-slate-200">${appState.adminDialogPlayer} has disconnected.</p>
            <div class="mt-4 grid gap-2">
              <button id="adminTerminateBtn" class="rounded-xl border border-rose-500/40 bg-rose-900/30 py-3">Forcibly terminate session</button>
              <button id="adminResetBtn" class="rounded-xl border border-amber-500/40 bg-amber-900/30 py-3">Kill room and start new lobby game</button>
              <button id="adminDismissBtn" class="rounded-xl border border-slate-600 py-3">Dismiss</button>
            </div>
          </div>
        </div>
      ` : "";

      const qrScanner = appState.qrScannerOpen ? `
        <div class="pointer-events-auto fixed inset-0 bg-black/85 p-4">
          <div class="mx-auto mt-8 w-full max-w-md rounded-2xl border border-slate-600 bg-slate-950 p-4">
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-bold text-amber-200">Scan Room QR</h3>
              <button id="closeQrBtn" class="rounded-lg border border-slate-600 px-2 py-1 text-xs">Close</button>
            </div>
            <video id="qrVideo" class="mt-3 aspect-square w-full rounded-xl border border-slate-700 bg-black" autoplay muted playsinline></video>
            <p class="mt-2 text-xs text-slate-400">Point your camera at the host QR code.</p>
          </div>
        </div>
      ` : "";

      const toasts = `<div class="absolute bottom-4 left-0 right-0 mx-auto flex w-full max-w-md flex-col gap-2 px-4">
        ${appState.toasts.map((t) => `<div class="rounded-lg border border-amber-500/40 bg-slate-900/95 px-3 py-2 text-sm">${t.message}</div>`).join("")}
      </div>`;

      el.overlayRoot.innerHTML = guide + adminDialog + qrScanner + toasts;
      const closeGuideBtn = document.getElementById("closeGuideBtn");
      if (closeGuideBtn) closeGuideBtn.addEventListener("click", closeGuide);
      const adminTerminateBtn = document.getElementById("adminTerminateBtn");
      if (adminTerminateBtn) adminTerminateBtn.addEventListener("click", adminTerminateSession);
      const adminResetBtn = document.getElementById("adminResetBtn");
      if (adminResetBtn) adminResetBtn.addEventListener("click", adminResetLobby);
      const adminDismissBtn = document.getElementById("adminDismissBtn");
      if (adminDismissBtn) adminDismissBtn.addEventListener("click", () => { appState.adminDialogPlayer = null; renderOverlays(); });
      const closeQrBtn = document.getElementById("closeQrBtn");
      if (closeQrBtn) closeQrBtn.addEventListener("click", closeQrScanner);
    }

    function render() {
      if (checkDeviceLock()) return;
      if (!appState.standalone) return;
      if (!appState.firebaseReady) return renderFirebaseSetup();
      if (!appState.user) return renderAuth();
      if (!appState.room) return renderHome();
      if (appState.room.phase === "lobby") return renderLobby(appState.room);
      return renderGame(appState.room);
    }

    async function bootstrap() {
      if ("serviceWorker" in navigator) {
        try { await navigator.serviceWorker.register("./sw.js"); } catch (_err) {}
      }

      navigator.serviceWorker && navigator.serviceWorker.addEventListener("message", (event) => {
        if (event.data && event.data.type === "NETWORK_CONTEXT") {
          console.log("Network context", event.data.payload);
        }
      });

      window.addEventListener("beforeinstallprompt", (e) => {
        e.preventDefault();
        appState.deferredPrompt = e;
        if (!appState.standalone) {
          showInstallGate("Tap Install App to Device to continue.");
        }
      });

      window.addEventListener("appinstalled", () => {
        appState.deferredPrompt = null;
        appState.standalone = isStandalone();
        hideInstallGate();
        render();
      });

      el.installBtn.addEventListener("click", async () => {
        if (!appState.deferredPrompt) {
          showInstallGate("Open browser menu and tap 'Add to Home Screen', then launch from your home screen.");
          return;
        }
        appState.deferredPrompt.prompt();
        await appState.deferredPrompt.userChoice;
      });

      el.openGuideBtn.addEventListener("click", openGuide);
      window.addEventListener("resize", render);
      window.addEventListener("orientationchange", render);

      appState.standalone = isStandalone();
      if (!appState.standalone) {
        showInstallGate("Install required before sign-in.");
        return render();
      }
      hideInstallGate();

      const firebaseOk = await initFirebase();
      if (!firebaseOk) return render();

      setupAuthListener();
      render();
    }

    bootstrap();
  </script>
</body>
</html>