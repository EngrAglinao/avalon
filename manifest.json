            Sign in with Google
          </span>
        </button>
      </div>
      <p class="text-parchment/30 font-inter text-xs text-center">Mobile portrait optimized · PWA enabled</p>
    </div>`;

  const input = document.getElementById('guestNameInput');
  if (input) {
    input.addEventListener('keydown', (e) => { if (e.key === 'Enter') authAsGuest(); });
  }
}

function authAsGuest() {
  const input = document.getElementById('guestNameInput');
  const name = (input ? input.value.trim() : '') || `Guest${Math.floor(Math.random()*9000+1000)}`;
  if (name.length < 2) { showToast('Enter at least 2 characters.', 'warn'); return; }
  GS.user = { uid: 'guest_' + Date.now(), name, email: null, isGuest: true };
  GS.isAdmin = false;
  showView('viewLobby');
  renderLobby();
}

async function authWithGoogle() {
  if (!GS.auth) { showToast('Firebase not configured.', 'warn'); return; }
  try {
    const provider = new firebase.auth.GoogleAuthProvider();
    await GS.auth.signInWithPopup(provider);
    // onAuthStateChanged handles the rest
  } catch(err) {
    showToast('Google Sign-In failed: ' + err.message, 'error');
  }
}

function handleSignOut() {
  if (GS.auth) GS.auth.signOut();
  GS.user = null; GS.isAdmin = false;
  closeNav();
  showView('viewAuth');
  renderAuth();
}

