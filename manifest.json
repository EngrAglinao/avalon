        <div class="border border-yellow-800/40 rounded-xl p-4 space-y-3 bg-panel/50">
          <label class="flex items-center justify-between text-sm text-parchment/80 font-inter">
            <span>🔮 Lady of the Lake</span>
            <input type="checkbox" id="hostLakeCheck" class="accent-yellow-400 w-5 h-5" />
          </label>
          <label class="flex items-center justify-between text-sm text-parchment/80 font-inter">
            <span>👥 Expected Players</span>
            <select id="hostPlayerCount" class="bg-slate-900 border border-yellow-700 text-yellow-200 text-xs rounded px-2 py-1">
              ${[5,6,7,8,9,10].map(n=>`<option value="${n}">${n}</option>`).join('')}
            </select>
          </label>
        </div>
      </div>
      <button onclick="hostRoom()" class="btn-gold w-full py-3.5 text-sm">🏰 Create Room</button>
      <div class="border-t border-yellow-800/30 pt-3">
        <p class="text-parchment/40 font-inter text-xs text-center leading-relaxed">
          As host, you control game flow and<br/>have access to room management tools.
        </p>
      </div>
    </div>`;
}

function renderJoinTab() {
  return `
    <div class="space-y-4 max-w-xs mx-auto anim-slide">
      <div>
        <label class="text-parchment/70 text-xs font-inter mb-1.5 block">Enter Room Code</label>
        <input id="joinCodeInput" class="input-gold text-center text-xl tracking-widest uppercase" type="text"
          placeholder="XXXX" maxlength="6" oninput="this.value=this.value.toUpperCase()" />
      </div>
      <button onclick="joinRoom()" class="btn-gold w-full py-3.5 text-sm">🚪 Join Room</button>
      <div class="border-t border-yellow-800/30 pt-4">
        <p class="font-cinzel-base text-yellow-400 text-xs mb-2">🌐 Available Local Rooms</p>
        <div id="localRoomsList" class="space-y-2">
          <p class="text-parchment/40 font-inter text-xs">Scanning for rooms...</p>
        </div>
      </div>
    </div>`;
}

async function hostRoom() {
  const lake = document.getElementById('hostLakeCheck')?.checked || false;
  const playerCount = parseInt(document.getElementById('hostPlayerCount')?.value || '6');
  const code = generateRoomCode();
  GS.roomCode = code;
  GS.isHost = true;
  GS.demoLake = lake;

  const hostPlayer = { id: GS.user.uid, name: GS.user.name, seat: 0, ready: false };
  GS.players = [hostPlayer];
  GS.myIndex = 0;
  GS.notepadFlags = [{ seat: 0, flag: 'neutral' }];

  if (GS.db) {
    try {
      await GS.db.ref(`rooms/${code}`).set({
        host: GS.user.uid,
        lake, playerCount,
        players: { 0: hostPlayer },
        phase: 'LOBBY',
        created: Date.now()
      });
      listenToRoom(code);
    } catch(err) { showToast('Room creation failed: ' + err.message, 'error'); return; }
  }

  showView('viewRoom');
  renderRoom();
}

async function joinRoom() {
  const code = document.getElementById('joinCodeInput')?.value.trim().toUpperCase();
  if (!code || code.length < 4) { showToast('Enter a valid room code.', 'warn'); return; }
  GS.roomCode = code;
  GS.isHost = false;

  if (GS.db) {
    try {
      const snap = await GS.db.ref(`rooms/${code}`).once('value');
      if (!snap.exists()) { showToast('Room not found.', 'error'); return; }
      const data = snap.val();
      const existingPlayers = data.players ? Object.values(data.players) : [];
      const seat = existingPlayers.length;
      const me = { id: GS.user.uid, name: GS.user.name, seat, ready: false };
      GS.myIndex = seat;
      await GS.db.ref(`rooms/${code}/players/${seat}`).set(me);
      listenToRoom(code);
    } catch(err) { showToast('Join failed: ' + err.message, 'error'); return; }
  } else {
    // Offline: just simulate
    const seat = 1;
    GS.myIndex = seat;
    GS.players = [
      { id: 'host', name: 'Host', seat: 0 },
      { id: GS.user.uid, name: GS.user.name, seat }
    ];
  }

  showView('viewRoom');
  renderRoom();
}

function generateRoomCode() {
  return Math.random().toString(36).substring(2, 8).toUpperCase();
}

function listenToRoom(code) {
  if (!GS.db) return;
  try {
    GS.db.ref(`rooms/${code}`).on('value', (snap) => {
      if (!snap.exists()) { showToast('Room was terminated.', 'error'); resetGame(); showView('viewLobby'); renderLobby(); return; }
      const data = snap.val();
      if (data.players) {
        GS.players = Object.values(data.players).sort((a,b) => a.seat - b.seat);
        GS.notepadFlags = GS.players.map(() => 'neutral');
      }
      if (data.phase && data.phase !== GS.phase) {
        GS.phase = data.phase;
        if (GS.phase === 'NIGHT') { startNightPhase(); return; }
        if (GS.phase !== 'LOBBY') { renderGame(); }
      }
      if (data.gameState) {
        Object.assign(GS, data.gameState);
      }
      const currentView = VIEWS.find(v => document.getElementById(v)?.style.display !== 'none');
      if (currentView === 'viewRoom') renderRoom();
    });

    // Presence / disconnect detection
    GS.db.ref(`rooms/${code}/players/${GS.myIndex}/connected`).set(true);
    GS.db.ref(`rooms/${code}/players/${GS.myIndex}/connected`).onDisconnect().set(false);
    GS.db.ref(`rooms/${code}/players`).on('value', (snap) => {
      if (!snap.exists()) return;
      const players = Object.values(snap.val());
      const disconnected = players.find(p => p.connected === false && p.seat !== GS.myIndex);
      const overlay = document.getElementById('disconnectOverlay');
      const msg = document.getElementById('disconnectMsg');
      if (disconnected && overlay && msg) {
        msg.textContent = `${disconnected.name} has disconnected. Waiting for host action...`;
        overlay.classList.add('visible');
      } else if (overlay) {
        overlay.classList.remove('visible');
      }
    });
  } catch(err) { console.error('[Room] Listen error:', err); }
}

// ══════════════════════════════════════════════════════
//  ROOM VIEW (Waiting Lobby)
// ══════════════════════════════════════════════════════
function renderRoom() {
  const v = document.getElementById('viewRoom');
  if (!v) return;
  const playerCount = GS.players.length;
  const minPlayers = 5;
  const canStart = playerCount >= minPlayers && GS.isHost;

  v.innerHTML = `
    <div class="flex items-center justify-between px-4 pt-4 pb-2 flex-shrink-0">
      <button onclick="openNav()" class="text-yellow-400 text-xl p-1">☰</button>
      <h1 class="font-cinzel text-sm text-yellow-400">Waiting Room</h1>
      <button onclick="leaveRoom()" class="text-parchment/50 text-xs font-inter py-1 px-2 border border-parchment/20 rounded">Leave</button>
    </div>
    <div class="flex-shrink-0 px-4 pb-3 text-center">
      <p class="text-parchment/50 font-inter text-xs mb-1">Room Code</p>
      <div class="room-code">${GS.roomCode || '——'}</div>
      <p class="text-parchment/40 font-inter text-xs mt-1">Share this code with your party</p>
    </div>
    <div class="flex-1 scroll-y px-4 space-y-2 pb-4">
      <p class="font-cinzel-base text-yellow-400 text-xs mb-1">Players (${playerCount}/10)</p>
      ${GS.players.map((p,i) => `
        <div class="flex items-center gap-3 bg-panel/60 border border-yellow-800/30 rounded-xl p-3">
          <div class="avatar-ring w-9 h-9 text-sm flex-shrink-0">${p.name.charAt(0).toUpperCase()}</div>
          <div class="flex-1">
            <p class="font-cinzel-base text-parchment text-sm">${p.name}</p>
            <p class="text-parchment/40 text-xs font-inter">${i===0?'Host':'Player '+(i+1)}</p>
          </div>
          ${p.ready ? '<span class="text-green-400 text-sm">✅</span>' : '<span class="text-parchment/30 text-sm">⏳</span>'}
        </div>`).join('')}
      <div class="border border-dashed border-yellow-800/30 rounded-xl p-3 flex items-center justify-center">
        <p class="text-parchment/30 font-inter text-xs">Waiting for more players... (min 5)</p>
      </div>
    </div>
    <div class="flex-shrink-0 px-4 pb-6 pt-2 space-y-2">
      ${GS.isHost ? `
        <button onclick="startGame()" class="btn-gold w-full py-3.5 text-sm ${!canStart?'opacity-50':''}" ${!canStart?'disabled':''}>
          ${canStart ? '⚔️ Start Game' : `Need ${minPlayers - playerCount} more player(s)`}
        </button>` : `
        <div class="text-center text-parchment/50 font-inter text-sm py-3">Waiting for host to start...</div>`}
    </div>`;
}

function leaveRoom() {
  if (GS.db && GS.roomCode) {
    try { GS.db.ref(`rooms/${GS.roomCode}/players/${GS.myIndex}`).remove(); } catch(e){}
  }
  resetGame();
  showView('viewLobby');
  renderLobby();
}

// ══════════════════════════════════════════════════════
//  GAME START
// ══════════════════════════════════════════════════════
function startGame() {
  if (!GS.isHost && !DEMO_MODE_ACTIVE) return;
  const playerCount = GS.players.length;
  if (playerCount < 5) { showToast('Need at least 5 players.', 'warn'); return; }

  // Assign roles
  const roleset = [...(GAME_TEXT_CONFIG.roleSets[playerCount] || GAME_TEXT_CONFIG.roleSets[5])];
  shuffleArray(roleset);
  GS.roles = roleset;
  GS.phase = 'NIGHT';
  GS.currentLeader = Math.floor(Math.random() * playerCount);
  GS.currentQuest = 0;
  GS.voteTracker = 0;
  GS.questResults = [];
  GS.nominatedSeats = [];
  GS.teamVotes = {};
  GS.questCards = [];
  GS.revealedCards = [];
  GS.ladyHolder = GS.demoLake ? (GS.currentLeader + playerCount - 1) % playerCount : null;
  GS.ladyHistory = GS.ladyHolder !== null ? [GS.ladyHolder] : [];
  GS.myNightReady = false;
  GS.notepadFlags = GS.players.map(() => 'neutral');

  // Set my role
  GS.myRole = GS.roles[GS.myIndex];

  if (GS.db && GS.roomCode) {
    try {
      GS.db.ref(`rooms/${GS.roomCode}`).update({
        phase: 'NIGHT',
        gameState: {
          roles: GS.roles,
          currentLeader: GS.currentLeader,
          currentQuest: GS.currentQuest,
          voteTracker: GS.voteTracker,
          questResults: GS.questResults,
          ladyHolder: GS.ladyHolder,
          ladyHistory: GS.ladyHistory,
          demoLake: GS.demoLake,
        }
      });
    } catch(e) { console.error(e); }
  }

  localStorage.setItem('avalon_games', (parseInt(localStorage.getItem('avalon_games')||'0')+1).toString());
  startNightPhase();
}

// ══════════════════════════════════════════════════════
//  NIGHT PHASE
// ══════════════════════════════════════════════════════
function startNightPhase() {
  GS.phase = 'NIGHT';
  GS.myNightReady = false;
  const overlay = document.getElementById('nightOverlay');
  if (!overlay) return;
  overlay.style.display = 'flex';
  overlay.style.flexDirection = 'column';
  overlay.style.alignItems = 'center';
  overlay.innerHTML = buildNightPhaseHTML();
  setupHoldReveal();
}

function buildNightPhaseHTML() {
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  const role = GS.roles[perspective];
  const roleInfo = GAME_TEXT_CONFIG.roles[role] || {};
  const isEvil = roleInfo.align === 'evil';
  const cardPath = getRoleCardPath(role);

  // Build visibility badges for all seats
  const visibilityBadges = getVisibilityBadges(perspective, role);

  return `
    <div class="w-full h-full flex flex-col" style="padding-top: ${DEMO_MODE_ACTIVE ? '50px' : '0'};">
      <!-- Stars background -->
      <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 50% 30%, #0a0c1a 0%, #000 100%);overflow:hidden;">
        ${generateStars()}
      </div>
      <!-- Content -->
      <div class="relative z-10 flex flex-col h-full px-4">
        <!-- Header -->
        <div class="text-center pt-6 pb-2 flex-shrink-0">
          <div class="font-cinzel text-yellow-400 text-lg">🌙 Night Phase</div>
          <div class="text-parchment/60 font-inter text-xs mt-1">The realm sleeps. Identities are revealed.</div>
        </div>

        <!-- Circle of players with badges -->
        <div class="relative flex-1 flex items-center justify-center">
          <div id="nightCircle" style="position:relative; width:280px; height:280px;">
            ${buildCircleSeats(perspective, visibilityBadges)}
            <!-- Center content -->
            <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;">
              <div class="font-cinzel text-yellow-400/60 text-xs">The Round</div>
              <div class="font-cinzel text-yellow-400 text-sm">Table</div>
            </div>
          </div>
        </div>

        <!-- Role card reveal -->
        <div class="flex-shrink-0 pb-4 space-y-3">
          <div id="roleCardArea" class="mx-auto" style="width:120px; height:180px; position:relative;">
            <!-- Hidden overlay -->
            <div id="roleCardHidden" class="card-frame" style="width:120px;height:180px;position:absolute;inset:0;cursor:pointer;user-select:none;touch-action:none;">
              <div class="card-placeholder">
                <div style="font-size:2rem;">🔒</div>
                <div style="font-size:10px;margin-top:6px;color:rgba(212,230,206,0.7);" class="font-cinzel-base">Hold to Reveal</div>
              </div>
            </div>
            <!-- Revealed card -->
            <div id="roleCardRevealed" class="card-frame ${isEvil?'evil-frame':''}" style="width:120px;height:180px;position:absolute;inset:0;opacity:0;transition:opacity 0.4s;">
              <div style="position:relative;width:100%;height:100%;">
                ${imgOrPlaceholder(cardPath, roleInfo.name || role)}
              </div>
              <div style="position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.8));padding:6px 4px;text-align:center;">
                <div class="font-cinzel-base text-xs ${isEvil?'text-red-400':'text-blue-300'}">${roleInfo.icon || ''} ${roleInfo.name || role}</div>
              </div>
            </div>
          </div>
          <!-- Vision text -->
          <div id="visionTextArea" style="display:none;" class="mx-4 text-center">
            <p class="text-parchment/80 font-inter text-xs leading-relaxed px-2">${GAME_TEXT_CONFIG.roleVision[role] || ''}</p>
          </div>
          <!-- Ready button -->
          <button id="nightReadyBtn" onclick="setNightReady()" class="btn-gold w-full mx-0 py-3 text-sm ${GS.myNightReady?'opacity-50':''}" style="margin:0 16px; width:calc(100% - 0px);">
            ${GS.myNightReady ? '✅ Ready!' : GAME_TEXT_CONFIG.ui.readyBtn}
          </button>
          <div id="nightWaitMsg" class="text-center text-parchment/40 font-inter text-xs" style="display:none;">
            Waiting for all players to be ready...
          </div>
        </div>
      </div>
    </div>`;
}

function generateStars() {
  let stars = '';
  for (let i = 0; i < 80; i++) {
    const x = Math.random() * 100;
    const y = Math.random() * 60;
    const s = Math.random() * 2 + 0.5;
    const o = Math.random() * 0.7 + 0.2;
    stars += `<div style="position:absolute;left:${x}%;top:${y}%;width:${s}px;height:${s}px;border-radius:50%;background:white;opacity:${o};"></div>`;
  }
  return stars;
}

function buildCircleSeats(perspective, visibilityBadges) {
  const count = GS.players.length;
  const radius = 110;
  const cx = 140, cy = 140;
  let html = '';

  GS.players.forEach((p, i) => {
    const angle = (2 * Math.PI * i / count) - Math.PI / 2;
    const x = cx + radius * Math.cos(angle) - 24;
    const y = cy + radius * Math.sin(angle) - 24;
    const badge = visibilityBadges[i];
    const isMe = i === (DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex);

    let ringClass = 'avatar-ring';
    if (badge === 'evil') ringClass += ' merlin-seen';
    else if (badge === 'percival') ringClass += ' percival-seen';
    else if (badge === 'evil-peer') ringClass += ' evil-peer';

    const badgeHtml = badge ? `<div style="position:absolute;top:-8px;left:50%;transform:translateX(-50%);font-size:9px;white-space:nowrap;background:rgba(0,0,0,0.8);border-radius:4px;padding:1px 4px;${badge==='evil'||badge==='evil-peer'?'color:#f87171':badge==='percival'?'color:#60a5fa':'color:#d4af37'};">${getBadgeLabel(badge)}</div>` : '';

    html += `<div style="position:absolute;left:${x}px;top:${y}px;">
      <div class="${ringClass} w-12 h-12 text-xs relative" style="font-size:11px;">
        ${isMe ? `<span class="font-bold text-yellow-400">${p.name.charAt(0)}</span>` : `<span class="text-parchment">${p.name.charAt(0)}</span>`}
        ${badgeHtml}
        <div style="position:absolute;bottom:-14px;left:50%;transform:translateX(-50%);white-space:nowrap;font-size:8px;color:rgba(242,230,206,0.6);font-family:Inter,sans-serif;">${isMe?'(You)':p.name.split(' ')[0]}</div>
      </div>
    </div>`;
  });
  return html;
}

function getVisibilityBadges(perspective, role) {
  const badges = {};
  const count = GS.players.length;
  const roles = GS.roles;

  if (role === 'merlin') {
    for (let i = 0; i < count; i++) {
      if (i === perspective) continue;
      const r = roles[i];
      // Merlin sees: morgana, assassin, oberon, evil_generic — NOT mordred
      if (['morgana','assassin','oberon','evil_generic'].includes(r)) badges[i] = 'evil';
    }
  } else if (role === 'percival') {
    for (let i = 0; i < count; i++) {
      if (i === perspective) continue;
      if (['merlin','morgana'].includes(roles[i])) badges[i] = 'percival';
    }
  } else if (['assassin','morgana','mordred','evil_generic'].includes(role)) {
    // Evil see each other (except oberon)
    for (let i = 0; i < count; i++) {
      if (i === perspective) continue;
      const r = roles[i];
      if (['assassin','morgana','mordred','evil_generic'].includes(r) && r !== 'oberon') {
        badges[i] = 'evil-peer';
      }
    }
  }
  // oberon: sees nobody special, nobody sees oberon
  return badges;
}

function getBadgeLabel(badge) {
  if (badge === 'evil') return '⚠️ Evil';
  if (badge === 'percival') return '❓ Merlin?';
  if (badge === 'evil-peer') return '🔴 Ally';
  return '';
}

function setupHoldReveal() {
  const hidden = document.getElementById('roleCardHidden');
  const revealed = document.getElementById('roleCardRevealed');
  const visionText = document.getElementById('visionTextArea');
  if (!hidden || !revealed) return;

  let holding = false, timer = null;

  const startHold = () => {
    holding = true;
    hidden.style.opacity = '0';
    revealed.style.opacity = '1';
    if (visionText) visionText.style.display = 'block';
  };
  const endHold = () => {
    holding = false;
    hidden.style.opacity = '1';
    revealed.style.opacity = '0';
    if (visionText) visionText.style.display = 'none';
  };

  hidden.addEventListener('mousedown', startHold);
  hidden.addEventListener('touchstart', (e) => { e.preventDefault(); startHold(); }, { passive: false });
  hidden.addEventListener('mouseup', endHold);
  hidden.addEventListener('mouseleave', endHold);
  hidden.addEventListener('touchend', endHold);
  hidden.addEventListener('touchcancel', endHold);
}

function setNightReady() {
  GS.myNightReady = true;
  const btn = document.getElementById('nightReadyBtn');
  const msg = document.getElementById('nightWaitMsg');
  if (btn) { btn.textContent = '✅ Ready!'; btn.classList.add('opacity-50'); }
  if (msg) msg.style.display = 'block';

  if (GS.db && GS.roomCode) {
    try { GS.db.ref(`rooms/${GS.roomCode}/players/${GS.myIndex}/ready`).set(true); } catch(e){}
  }

  // In demo mode or offline, advance after brief delay
  if (DEMO_MODE_ACTIVE || !GS.db) {
    setTimeout(() => {
      advanceToNomination();
    }, 1500);
  }
}

function advanceToNomination() {
  const overlay = document.getElementById('nightOverlay');
  if (overlay) overlay.style.display = 'none';
  GS.phase = 'NOMINATION';
  showView('viewGame');
  renderGame();
}

// ══════════════════════════════════════════════════════
//  MAIN GAME VIEW
// ══════════════════════════════════════════════════════
function renderGame() {
  const v = document.getElementById('viewGame');
  if (!v) return;

  const demoOffset = DEMO_MODE_ACTIVE ? 'padding-top:52px;' : '';
  v.style = demoOffset;

  v.innerHTML = `
    <!-- Top bar -->
    <div class="flex items-center justify-between px-3 pt-3 pb-1 flex-shrink-0">
      <button onclick="openNav()" class="text-yellow-400 text-lg p-1">☰</button>
      <div class="text-center">
        <div class="font-cinzel text-yellow-400 text-xs">${GAME_TEXT_CONFIG.phases[GS.phase] || GS.phase}</div>
        <div class="text-parchment/50 font-inter" style="font-size:10px;">Quest ${GS.currentQuest+1} · Leader: ${GS.players[GS.currentLeader]?.name || '?'}</div>
      </div>
      ${GS.isAdmin ? `<button onclick="openAdmin()" class="text-yellow-400 text-lg p-1">⚙️</button>` : '<div class="w-8"></div>'}
    </div>

    <!-- Quest board -->
    <div class="flex-shrink-0 px-3 py-1">
      ${renderQuestBoard()}
    </div>

    <!-- Vote tracker -->
    <div class="flex-shrink-0 px-3 pb-1">
      ${renderVoteTracker()}
    </div>

    <!-- Player circle area -->
    <div class="flex-1 relative flex items-center justify-center min-h-0">
      <div id="gameCircle" style="position:relative; width:300px; height:300px; flex-shrink:0;">
        ${buildGameCircle()}
      </div>
    </div>

    <!-- Phase action panel -->
    <div class="flex-shrink-0 px-3 pb-4 pt-1 scroll-y" style="max-height:280px;">
      <div id="phasePanel" class="anim-slide">
        ${renderPhasePanel()}
      </div>
    </div>`;
}

function renderQuestBoard() {
  const count = GS.players.length;
  const sizes = GAME_TEXT_CONFIG.questSizes[count] || GAME_TEXT_CONFIG.questSizes[5];
  const twoFail = GAME_TEXT_CONFIG.twoFailRequired[count];

  let html = `<div class="flex gap-1.5 justify-center">`;
  for (let i = 0; i < 5; i++) {
    const result = GS.questResults[i];
    let cls = 'quest-slot';
    let icon = '';
    if (result === 'success') { cls += ' success'; icon = '✅'; }
    else if (result === 'fail') { cls += ' fail'; icon = '❌'; }
    else if (i === GS.currentQuest) cls += ' active';

    html += `<div class="${cls}" style="width:52px;height:60px;font-size:9px;">
      <div style="font-size:${result?'18px':'11px'};">${icon || sizes[i]}</div>
      <div style="font-size:8px;color:rgba(212,175,55,0.7);">Q${i+1}</div>
      ${twoFail === i && !result ? '<div style="font-size:7px;color:#fca5a5;">2✗</div>' : ''}
    </div>`;
  }
  html += `</div>`;
  return html;
}

function renderVoteTracker() {
  let html = `<div class="flex items-center gap-1 justify-center">
    <span class="text-parchment/50 font-inter" style="font-size:9px;">VOTES:</span>`;
  for (let i = 0; i < 5; i++) {
    let cls = 'vote-tracker-dot';
    if (i < GS.voteTracker) cls += ' active';
    if (i === 4) cls += ' hammer';
    html += `<div class="${cls}"><span style="font-size:8px;">${i===4?'🔨':''}</span></div>`;
  }
  html += `</div>`;
  return html;
}

function buildGameCircle() {
  const count = GS.players.length;
  const radius = 115;
  const cx = 150, cy = 150;
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  let html = '';

  GS.players.forEach((p, i) => {
    const angle = (2 * Math.PI * i / count) - Math.PI / 2;
    const x = cx + radius * Math.cos(angle) - 26;
    const y = cy + radius * Math.sin(angle) - 26;
    const isMe = i === perspective;
    const isLeader = i === GS.currentLeader;
    const isNominated = GS.nominatedSeats.includes(i);
    const hasLady = GS.ladyHolder === i && GS.demoLake;
    const voteDone = GS.teamVotes[i] !== undefined;

    let ringClass = 'avatar-ring';
    if (isNominated) ringClass += ' selected-ring';
    else if (GS.nominatedSeats.length > 0 && !isNominated && GS.phase === 'NOMINATION') ringClass += ' dimmed';

    html += `<div style="position:absolute;left:${x}px;top:${y}px;" onclick="${GS.phase==='NOMINATION' && GS.currentLeader === perspective ? `toggleNominate(${i})` : GS.phase==='ASSASSIN' && (GS.roles[perspective]==='assassin'||DEMO_MODE_ACTIVE) ? `setAssassinTarget(${i})` : GS.phase==='LADY' && GS.ladyHolder===perspective ? `setLadyTarget(${i})` : ''}">
      <div class="${ringClass} w-12 h-12 relative" style="font-size:11px; cursor:${GS.phase==='NOMINATION'&&GS.currentLeader===perspective||GS.phase==='ASSASSIN'||GS.phase==='LADY'?'pointer':'default'}">
        <span class="${isMe?'text-yellow-400 font-bold':'text-parchment'}">${p.name.charAt(0)}</span>
        ${isLeader ? `<div style="position:absolute;top:-10px;left:50%;transform:translateX(-50%);font-size:12px;">👑</div>` : ''}
        ${hasLady ? `<div style="position:absolute;bottom:-10px;left:50%;transform:translateX(-50%);font-size:12px;">🔮</div>` : ''}
        ${voteDone && GS.phase==='TEAM_VOTE' ? `<div style="position:absolute;top:-8px;right:-8px;font-size:10px;background:rgba(0,0,0,0.8);border-radius:3px;padding:1px 3px;">${GS.teamVotes[i]==='approve'?'✅':'❌'}</div>` : ''}
        ${GS.assassinTarget===i ? `<div style="position:absolute;inset:-2px;border-radius:50%;border:2px solid #f87171;box-shadow:0 0 14px rgba(248,113,113,0.7);"></div>` : ''}
        <div style="position:absolute;bottom:-14px;left:50%;transform:translateX(-50%);white-space:nowrap;font-size:8px;color:rgba(242,230,206,${isMe?'0.9':'0.5'});font-family:Inter,sans-serif;">${isMe?'(You)':p.name.split(' ')[0].substring(0,6)}</div>
      </div>
    </div>`;
  });

  // Center: quest progress or action
  html += `<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;">
    <div style="font-size:10px;color:rgba(212,175,55,0.6);font-family:Cinzel,serif;">Good: ${GS.questResults.filter(r=>r==='success').length} | Evil: ${GS.questResults.filter(r=>r==='fail').length}</div>
  </div>`;

  return html;
}

function toggleNominate(seat) {
  if (GS.phase !== 'NOMINATION') return;
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  if (GS.currentLeader !== perspective) return;

  const count = GS.players.length;
  const questSize = (GAME_TEXT_CONFIG.questSizes[count] || GAME_TEXT_CONFIG.questSizes[5])[GS.currentQuest];
  const idx = GS.nominatedSeats.indexOf(seat);

  if (idx > -1) {
    GS.nominatedSeats.splice(idx, 1);
  } else {
    if (GS.nominatedSeats.length >= questSize) {
      showToast(`Max ${questSize} players for this quest.`, 'warn');
      return;
    }
    GS.nominatedSeats.push(seat);
  }
  renderGame();
}

function renderPhasePanel() {
  switch (GS.phase) {
    case 'NOMINATION': return renderNominationPanel();
    case 'TEAM_VOTE':  return renderTeamVotePanel();
    case 'QUEST_VOTE': return renderQuestVotePanel();
    case 'REVEAL':     return renderRevealPanel();
    case 'LADY':       return renderLadyPanel();
    case 'ASSASSIN':   return renderAssassinPanel();
    default: return `<p class="text-parchment/50 text-sm text-center font-inter">Phase: ${GS.phase}</p>`;
  }
}

// ── NOMINATION PANEL ──
function renderNominationPanel() {
  const count = GS.players.length;
  const questSize = (GAME_TEXT_CONFIG.questSizes[count] || GAME_TEXT_CONFIG.questSizes[5])[GS.currentQuest];
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  const isLeader = GS.currentLeader === perspective;

  return `<div class="space-y-2">
    <p class="font-cinzel-base text-yellow-400 text-xs text-center">
      ${isLeader ? `Select ${questSize} players for Quest ${GS.currentQuest+1}` : `Waiting for ${GS.players[GS.currentLeader]?.name} to nominate...`}
    </p>
    <div class="flex flex-wrap gap-2 justify-center">
      ${GS.players.map((p,i) => {
        const sel = GS.nominatedSeats.includes(i);
        return `<button onclick="toggleNominate(${i})" class="nominate-btn ${sel?'selected':''} ${!isLeader?'opacity-50 pointer-events-none':''}"
          style="${sel?'border-color:#d4af37;background:rgba(212,175,55,0.2);':''}">
          ${sel?'✅ ':''}${p.name}
        </button>`;
      }).join('')}
    </div>
    ${isLeader && GS.nominatedSeats.length === questSize ? `
      <button onclick="submitNomination()" class="btn-gold w-full py-3 text-sm">
        ⚔️ Propose Team (${GS.nominatedSeats.map(s=>GS.players[s]?.name).join(', ')})
      </button>` : ''}
  </div>`;
}

function submitNomination() {
  const count = GS.players.length;
  const questSize = (GAME_TEXT_CONFIG.questSizes[count] || GAME_TEXT_CONFIG.questSizes[5])[GS.currentQuest];
  if (GS.nominatedSeats.length !== questSize) {
    showToast(`Select exactly ${questSize} players.`, 'warn');
    return;
  }
  GS.phase = 'TEAM_VOTE';
  GS.teamVotes = {};
  GS.myVote = null;
  renderGame();
}

// ── TEAM VOTE PANEL ──
function renderTeamVotePanel() {
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  const myVote = GS.teamVotes[perspective];
  const allVoted = Object.keys(GS.teamVotes).length === GS.players.length;
  const teamNames = GS.nominatedSeats.map(s => GS.players[s]?.name).join(', ');

  return `<div class="space-y-2">
    <p class="font-cinzel-base text-yellow-400 text-xs text-center">Proposed Team: <span class="text-parchment">${teamNames}</span></p>
    <p class="text-parchment/60 font-inter text-center" style="font-size:10px;">Vote: Approve or Reject this team?</p>
    ${myVote ? `<div class="text-center">
        <span class="font-cinzel-base text-sm ${myVote==='approve'?'text-green-400':'text-red-400'}">${myVote==='approve'?'✅ You Approved':'❌ You Rejected'}</span>
        <p class="text-parchment/40 font-inter text-xs mt-1">Waiting for others... (${Object.keys(GS.teamVotes).length}/${GS.players.length})</p>
      </div>` : `
      <div class="flex gap-2">
        <button onclick="castTeamVote('approve')" class="btn-good flex-1 py-3 text-sm">${GAME_TEXT_CONFIG.ui.voteApprove}</button>
        <button onclick="castTeamVote('reject')" class="btn-danger flex-1 py-3 text-sm">${GAME_TEXT_CONFIG.ui.voteReject}</button>
      </div>`}
    ${allVoted ? `<button onclick="resolveTeamVote()" class="btn-gold w-full py-2 text-xs">Reveal Votes →</button>` : ''}
  </div>`;
}

function castTeamVote(vote) {
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  GS.teamVotes[perspective] = vote;
  renderGame();
  if (Object.keys(GS.teamVotes).length === GS.players.length) {
    setTimeout(resolveTeamVote, 800);
  }
}

function resolveTeamVote() {
  const votes = Object.values(GS.teamVotes);
  const approvals = votes.filter(v => v === 'approve').length;
  const majority = Math.ceil(GS.players.length / 2);

  if (approvals >= majority) {
    GS.phase = 'QUEST_VOTE';
    GS.questCards = [];
    GS.myQuestCard = null;
    showToast(`Team approved! (${approvals}✅ vs ${votes.length-approvals}❌)`, 'success');
    renderGame();
  } else {
    GS.voteTracker++;
    showToast(`Team rejected! (${approvals}✅ vs ${votes.length-approvals}❌)`, 'warn');
    if (GS.voteTracker >= 5) {
      // 5th rejection: evil wins automatically
      showToast('5 consecutive rejections! Evil wins!', 'error');
      endGame('evil');
      return;
    }
    // Pass leadership
    GS.currentLeader = (GS.currentLeader + 1) % GS.players.length;
    GS.phase = 'NOMINATION';
    GS.nominatedSeats = [];
    GS.teamVotes = {};
    renderGame();
  }
}

// ── QUEST VOTE PANEL ──
function renderQuestVotePanel() {
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  const role = GS.roles[perspective];
  const isOnQuest = GS.nominatedSeats.includes(perspective);
  const myCard = GS.myQuestCard;
  const allSubmitted = GS.questCards.length === GS.nominatedSeats.length;

  if (!isOnQuest) {
    return `<div class="text-center space-y-2">
      <p class="font-cinzel-base text-yellow-400 text-xs">Quest in Progress</p>
      <p class="text-parchment/60 font-inter text-xs">Team: ${GS.nominatedSeats.map(s=>GS.players[s]?.name).join(', ')}</p>
      <p class="text-parchment/40 font-inter text-xs">Waiting for quest cards... (${GS.questCards.length}/${GS.nominatedSeats.length})</p>
    </div>`;
  }

  const isEvil = ['assassin','morgana','mordred','oberon','evil_generic'].includes(role);
  const goodWarn = !isEvil;

  return `<div class="space-y-2">
    <p class="font-cinzel-base text-yellow-400 text-xs text-center">Choose your Quest Card</p>
    ${myCard ? `<div class="text-center">
        <span class="font-cinzel-base text-sm ${myCard==='success'?'text-green-400':'text-red-400'}">${myCard==='success'?'✅ Success submitted':'❌ Fail submitted'}</span>
        <p class="text-parchment/40 font-inter text-xs mt-1">Waiting... (${GS.questCards.length}/${GS.nominatedSeats.length})</p>
      </div>` : `
      <div class="flex gap-2">
        <button onclick="submitQuestCard('success')" class="btn-good flex-1 py-3 text-sm">✅ SUCCESS</button>
        ${isEvil || !goodWarn ? '' : ''}
        <button onclick="submitQuestCard('fail')" class="btn-danger flex-1 py-3 text-sm" ${goodWarn?'': ''}>❌ FAIL</button>
      </div>
      ${goodWarn ? `<div id="goodWarnMsg" class="warn-pulse text-center" style="display:none;">
        <p class="text-yellow-300 font-inter text-xs">${GAME_TEXT_CONFIG.ui.goodWarnMsg}</p>
      </div>` : ''}`}
    ${allSubmitted && GS.isHost ? `<button onclick="revealQuestResult()" class="btn-gold w-full py-2 text-xs">Reveal Quest →</button>` : ''}
  </div>`;
}

function submitQuestCard(card) {
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  const role = GS.roles[perspective];
  const isGood = ['merlin','percival','good_generic'].includes(role);

  if (card === 'fail' && isGood) {
    const warn = document.getElementById('goodWarnMsg');
    if (warn) warn.style.display = 'block';
    // Still allow after warning
    setTimeout(() => { if (warn) warn.style.display = 'none'; }, 2000);
  }

  GS.myQuestCard = card;
  GS.questCards.push(card);
  shuffleArray(GS.questCards); // Anonymize order
  renderGame();

  if (GS.questCards.length === GS.nominatedSeats.length) {
    setTimeout(() => {
      GS.phase = 'REVEAL';
      GS.revealedCards = [];
      renderGame();
    }, 600);
  }
}

// ── REVEAL PANEL ──
function renderRevealPanel() {
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  const isLeader = GS.currentLeader === perspective;
  const totalCards = GS.questCards.length;
  const revealed = GS.revealedCards.length;
  const allRevealed = revealed >= totalCards;

  const successes = GS.questCards.filter(c => c === 'success').length;
  const fails = GS.questCards.filter(c => c === 'fail').length;

  return `<div class="space-y-3">
    <p class="font-cinzel-base text-yellow-400 text-xs text-center">Quest Result Reveal</p>
    <!-- Card slots -->
    <div class="flex justify-center gap-2 flex-wrap">
      ${GS.questCards.map((card, i) => {
        const isRevealed = i < GS.revealedCards.length;
        return `<div onclick="${isLeader && i === GS.revealedCards.length ? 'revealNextCard()' : ''}" style="width:52px;height:76px;border-radius:8px;border:1.5px solid ${isRevealed?(card==='success'?'#22c55e':'#c00'):'#d4af37'};background:${isRevealed?(card==='success'?'rgba(20,60,20,0.8)':'rgba(60,10,10,0.8)'):'rgba(20,24,35,0.8)'};display:flex;align-items:center;justify-content:center;cursor:${isLeader&&i===GS.revealedCards.length?'pointer':'default'};transition:all 0.3s;position:relative;overflow:hidden;">
          ${isRevealed ? `<span style="font-size:22px;">${card==='success'?'✅':'❌'}</span>` : `<span style="font-size:18px;">🎴</span>`}
          ${!isRevealed && i === GS.revealedCards.length && isLeader ? `<div style="position:absolute;bottom:0;left:0;right:0;background:rgba(212,175,55,0.15);font-size:8px;color:#d4af37;text-align:center;padding:2px;font-family:Cinzel,serif;">Tap</div>` : ''}
        </div>`;
      }).join('')}
    </div>
    ${allRevealed ? `
      <div class="text-center border border-yellow-700/40 rounded-xl p-3 bg-panel/60">
        <p class="font-cinzel-base text-sm">⚔️ ${successes} SUCCESS &nbsp;|&nbsp; 💀 ${fails} FAIL</p>
        <p class="text-parchment/60 font-inter text-xs mt-1">${getQuestResultText(fails)}</p>
      </div>
      ${(GS.isHost || DEMO_MODE_ACTIVE) ? `<button onclick="finalizeQuestResult(${fails})" class="btn-gold w-full py-2.5 text-sm">Continue →</button>` : ''}
    ` : `<p class="text-center text-parchment/50 font-inter text-xs">${isLeader ? 'Tap each card to reveal →' : 'Waiting for leader to reveal...'}</p>`}
  </div>`;
}

function getQuestResultText(fails) {
  const count = GS.players.length;
  const twoFail = GAME_TEXT_CONFIG.twoFailRequired[count];
  const needsTwoFails = twoFail === GS.currentQuest;
  if (needsTwoFails) {
    return fails >= 2 ? '❌ Quest FAILED (2 fails required, got ' + fails + ')' : fails === 1 ? '⚠️ 1 Fail Card — but 2 were needed. Quest SUCCEEDS!' : '✅ Quest SUCCEEDED!';
  }
  return fails >= 1 ? '❌ Quest FAILED!' : '✅ Quest SUCCEEDED!';
}

function revealNextCard() {
  if (GS.revealedCards.length < GS.questCards.length) {
    GS.revealedCards.push(GS.questCards[GS.revealedCards.length]);
    renderGame();
  }
}

function finalizeQuestResult(fails) {
  const count = GS.players.length;
  const twoFail = GAME_TEXT_CONFIG.twoFailRequired[count];
  const needsTwoFails = twoFail === GS.currentQuest;
  const questFailed = needsTwoFails ? fails >= 2 : fails >= 1;

  GS.questResults[GS.currentQuest] = questFailed ? 'fail' : 'success';
  GS.voteTracker = 0;

  const successes = GS.questResults.filter(r => r === 'success').length;
  const failures = GS.questResults.filter(r => r === 'fail').length;

  const logEntry = `Quest ${GS.currentQuest+1}: ${questFailed?'FAIL':'SUCCESS'}`;
  GS.gameLog.push(logEntry);

  if (successes >= 3) {
    // Good wins — check assassination
    GS.phase = 'ASSASSIN';
    renderGame();
    return;
  }
  if (failures >= 3) {
    endGame('evil');
    return;
  }

  // Check lady of the lake
  if (GS.demoLake && GS.currentQuest >= 1 && GS.currentQuest <= 3) {
    GS.phase = 'LADY';
    renderGame();
    return;
  }

  advanceQuest();
}

function advanceQuest() {
  GS.currentQuest++;
  GS.currentLeader = (GS.currentLeader + 1) % GS.players.length;
  GS.phase = 'NOMINATION';
  GS.nominatedSeats = [];
  GS.teamVotes = {};
  renderGame();
}

// ── LADY OF THE LAKE PANEL ──
function renderLadyPanel() {
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  const hasLady = GS.ladyHolder === perspective;
  const holderName = GS.players[GS.ladyHolder]?.name || '?';
  const eligibleSeats = GS.players
    .map((p,i) => i)
    .filter(i => !GS.ladyHistory.includes(i) && i !== GS.ladyHolder);

  return `<div class="space-y-2">
    <p class="font-cinzel-base text-yellow-400 text-xs text-center">🔮 Lady of the Lake</p>
    <p class="text-parchment/60 font-inter text-center" style="font-size:11px;">${hasLady ? GAME_TEXT_CONFIG.ui.ladyPrompt : `${holderName} holds the Lady token.`}</p>
    ${hasLady ? `
      <div class="flex flex-wrap gap-2 justify-center">
        ${eligibleSeats.map(i => `
          <button onclick="setLadyTarget(${i})" class="nominate-btn ${GS.assassinTarget===i?'selected':''}">
            🔍 ${GS.players[i]?.name}
          </button>`).join('')}
      </div>
      ${GS.assassinTarget !== null && eligibleSeats.includes(GS.assassinTarget) ? `
        <button onclick="confirmLadyInvestigation()" class="btn-gold w-full py-2.5 text-sm">🔮 Investigate ${GS.players[GS.assassinTarget]?.name}</button>
      ` : ''}
    ` : `<p class="text-center text-parchment/40 font-inter text-xs">Waiting for ${holderName}...</p>`}
  </div>`;
}

function setLadyTarget(seat) {
  GS.assassinTarget = seat;
  if (GS.phase === 'LADY') renderGame();
  if (GS.phase === 'ASSASSIN') renderGame();
}

function confirmLadyInvestigation() {
  const targetSeat = GS.assassinTarget;
  if (targetSeat === null) return;
  const targetRole = GS.roles[targetSeat];
  const targetInfo = GAME_TEXT_CONFIG.roles[targetRole];
  const alignment = targetInfo?.align === 'good' ? '🔵 GOOD' : '🔴 EVIL';
  showToast(`${GS.players[targetSeat]?.name} is ${alignment}!`, targetInfo?.align === 'good' ? 'success' : 'error', 4000);

  // Pass lady token
  GS.ladyHistory.push(targetSeat);
  GS.ladyHolder = targetSeat;
  GS.assassinTarget = null;
  GS.gameLog.push(`Lady: ${GS.players[targetSeat]?.name} is ${alignment}`);
  setTimeout(advanceQuest, 2000);
}

// ── ASSASSIN PANEL ──
function renderAssassinPanel() {
  const perspective = DEMO_MODE_ACTIVE ? GS.demoPerspective : GS.myIndex;
  const role = GS.roles[perspective];
  const isAssassin = role === 'assassin';

  return `<div class="space-y-2">
    <p class="font-cinzel-base text-yellow-400 text-xs text-center">🗡️ Assassination Phase</p>
    <p class="text-parchment/60 font-inter text-center" style="font-size:11px;">
      ${isAssassin ? GAME_TEXT_CONFIG.ui.assassinPrompt : `The Assassin is choosing their target...`}
    </p>
    ${isAssassin ? `
      <div class="flex flex-wrap gap-2 justify-center">
        ${GS.players.map((p,i) => {
          if (GS.roles[i] === 'assassin') return '';
          return `<button onclick="setAssassinTarget(${i})" class="nominate-btn ${GS.assassinTarget===i?'selected':''}">
            🗡️ ${p.name}
          </button>`;
        }).join('')}
      </div>
      ${GS.assassinTarget !== null ? `
        <button onclick="confirmAssassination()" class="btn-danger w-full py-2.5 text-sm">
          🗡️ Assassinate ${GS.players[GS.assassinTarget]?.name}
        </button>` : ''}
    ` : '<p class="text-center text-parchment/40 font-inter text-xs">Observing...</p>'}
  </div>`;
}

function setAssassinTarget(seat) {
  GS.assassinTarget = seat;
  renderGame();
}

function confirmAssassination() {
  if (GS.assassinTarget === null) return;
  const targetRole = GS.roles[GS.assassinTarget];
  const targetName = GS.players[GS.assassinTarget]?.name;

  if (targetRole === 'merlin') {
    showToast(`🗡️ ${targetName} was Merlin! Evil wins by assassination!`, 'error', 5000);
    endGame('evil_assassin');
  } else {
    showToast(`${targetName} was not Merlin! Good wins!`, 'success', 5000);
    endGame('good');
  }
}

function advancePhase() {
  const order = ['NOMINATION','TEAM_VOTE','QUEST_VOTE','REVEAL','LADY','ASSASSIN'];
  const idx = order.indexOf(GS.phase);
  if (idx < order.length - 1) {
    GS.phase = order[idx + 1];
    renderGame();
  }
}

// ══════════════════════════════════════════════════════
//  END GAME
// ══════════════════════════════════════════════════════
function endGame(winner) {
  GS.phase = 'END';
  showView('viewEnd');
  renderEndScreen(winner);
}

function renderEndScreen(winner) {
  const v = document.getElementById('viewEnd');
  if (!v) return;

  const goodWin = winner === 'good';
  const assassinated = winner === 'evil_assassin';

  const titles = {
    good: '⚔️ Good Triumphs!',
    evil: '💀 Evil Prevails!',
    evil_assassin: '🗡️ Merlin is Slain!'
  };
  const subtitles = {
    good: 'The Knights of the Round Table have completed their sacred quests.',
    evil: 'The forces of darkness have corrupted Camelot.',
    evil_assassin: 'The Assassin\'s blade found Merlin. Evil seizes victory!'
  };

  const rolesReveal = GS.players.map((p, i) => {
    const role = GS.roles[i] || 'good_generic';
    const info = GAME_TEXT_CONFIG.roles[role] || {};
    return `<div class="flex items-center gap-2 py-1.5 border-b border-yellow-800/20">
      <div style="width:32px;height:44px;border-radius:5px;border:1px solid ${info.align==='evil'?'#c00':'#d4af37'};background:#1a1e2a;display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;">${info.icon||'🎴'}</div>
      <div class="flex-1">
        <p class="font-cinzel-base text-sm ${info.align==='evil'?'text-red-400':'text-blue-300'}">${p.name}</p>
        <p class="text-parchment/50 font-inter text-xs">${info.name||role}</p>
      </div>
    </div>`;
  }).join('');

  v.innerHTML = `
    <div class="flex-shrink-0 pt-8 pb-4 px-6 text-center">
      <div class="text-5xl mb-3">${goodWin ? '🏆' : assassinated ? '🗡️' : '💀'}</div>
      <h1 class="font-cinzel text-xl ${goodWin?'text-yellow-400':'text-red-400'} leading-tight">${titles[winner]}</h1>
      <p class="text-parchment/60 font-inter text-xs mt-2 leading-relaxed">${subtitles[winner]}</p>
      <!-- Quest tally -->
      <div class="flex justify-center gap-1.5 mt-4">
        ${GS.questResults.map((r,i) => `<div class="w-10 h-10 rounded-lg border flex items-center justify-center text-lg ${r==='success'?'border-green-700 bg-green-900/40':'border-red-700 bg-red-900/40'}">${r==='success'?'✅':'❌'}</div>`).join('')}
      </div>
    </div>
    <div class="flex-1 scroll-y px-4 pb-2">
      <p class="font-cinzel-base text-yellow-400 text-xs mb-2">Role Reveal</p>
      ${rolesReveal}
    </div>
    <div class="flex-shrink-0 px-4 pb-8 pt-3 space-y-2">
      <button onclick="resetAndLobby()" class="btn-gold w-full py-3.5 text-sm">🏰 Return to Lobby</button>
    </div>`;
}

function resetAndLobby() {
  resetGame();
  showView('viewLobby');
  renderLobby();
}

function resetGame() {
  GS.phase = 'SETUP';
  GS.roomCode = null;
  GS.isHost = false;
  GS.players = [];
  GS.myIndex = 0;
  GS.myRole = null;
  GS.roles = [];
  GS.currentQuest = 0;
  GS.currentLeader = 0;
  GS.voteTracker = 0;
  GS.questResults = [];
  GS.nominatedSeats = [];
  GS.teamVotes = {};
  GS.questCards = [];
  GS.revealedCards = [];
  GS.ladyHolder = null;
  GS.ladyHistory = [];
  GS.assassinTarget = null;
  GS.myNightReady = false;
  GS.myVote = null;
  GS.myQuestCard = null;
  GS.notepadFlags = [];
  GS.gameLog = [];
}

// ══════════════════════════════════════════════════════
//  DEMO MODE ENGINE
// ══════════════════════════════════════════════════════
function startDemoMode() {
  const strip = document.getElementById('demoStrip');
  if (strip) strip.style.display = 'block';

  GS.demoPlayers = 6;
  GS.demoLake = false;
  GS.demoPerspective = 0;

  initDemoGame();
  setupDemoControls();
}

function initDemoGame() {
  const n = GS.demoPlayers;
  const names = ['You','Aria','Bran','Caius','Dana','Elric','Fiona','Gareth','Hilde','Ivan'];
  GS.players = Array.from({length: n}, (_, i) => ({ id: `p${i}`, name: names[i] || `Bot${i}`, seat: i }));
  GS.myIndex = 0;
  GS.isHost = true;
  GS.user = { uid: 'demo', name: 'You', email: null, isGuest: true };

  const roleset = [...(GAME_TEXT_CONFIG.roleSets[n] || GAME_TEXT_CONFIG.roleSets[5])];
  shuffleArray(roleset);
  GS.roles = roleset;
  GS.myRole = GS.roles[0];

  GS.phase = 'NIGHT';
  GS.currentLeader = 0;
  GS.currentQuest = 0;
  GS.voteTracker = 0;
  GS.questResults = [];
  GS.nominatedSeats = [];
  GS.teamVotes = {};
  GS.questCards = [];
  GS.revealedCards = [];
  GS.ladyHolder = GS.demoLake ? (GS.players.length - 1) : null;
  GS.ladyHistory = GS.ladyHolder !== null ? [GS.ladyHolder] : [];
  GS.assassinTarget = null;
  GS.myNightReady = false;
  GS.notepadFlags = GS.players.map(() => 'neutral');
  GS.gameLog = [];

  updateDemoPerspectiveDropdown();
  startNightPhase();
}

function setupDemoControls() {
  const slider = document.getElementById('demoPlayerSlider');
  const countLabel = document.getElementById('demoPlayerCount');
  const lakeCheck = document.getElementById('demoLakeCheck');
  const perspDrop = document.getElementById('demoPerspective');
  const botBtn = document.getElementById('demoBotBtn');
  const restartBtn = document.getElementById('demoRestartBtn');

  if (slider) {
    slider.addEventListener('input', () => {
      GS.demoPlayers = parseInt(slider.value);
      if (countLabel) countLabel.textContent = GS.demoPlayers;
    });
    slider.addEventListener('change', () => { initDemoGame(); });
  }
  if (lakeCheck) {
    lakeCheck.addEventListener('change', () => {
      GS.demoLake = lakeCheck.checked;
    });
  }
  if (perspDrop) {
    perspDrop.addEventListener('change', () => {
      GS.demoPerspective = parseInt(perspDrop.value);
      // Refresh night phase or game view
      if (GS.phase === 'NIGHT') startNightPhase();
      else renderGame();
    });
  }
  if (botBtn) botBtn.addEventListener('click', executeBotAction);
  if (restartBtn) restartBtn.addEventListener('click', initDemoGame);
}

function updateDemoPerspectiveDropdown() {
  const drop = document.getElementById('demoPerspective');
  if (!drop) return;
  drop.innerHTML = GS.players.map((p, i) =>
    `<option value="${i}">${i===0?'You':p.name} (${GAME_TEXT_CONFIG.roles[GS.roles[i]]?.name||GS.roles[i]})</option>`
  ).join('');
  drop.value = GS.demoPerspective;
}

// ── BOT AI ENGINE ──
function executeBotAction() {
  try {
    switch (GS.phase) {
      case 'NIGHT':
        GS.myNightReady = true;
        advanceToNomination();
        break;
      case 'NOMINATION':
        botNominate();
        break;
      case 'TEAM_VOTE':
        botVoteAll();
        break;
      case 'QUEST_VOTE':
        botQuestCardsAll();
        break;
      case 'REVEAL':
        // Reveal all remaining cards
        while (GS.revealedCards.length < GS.questCards.length) {
          GS.revealedCards.push(GS.questCards[GS.revealedCards.length]);
        }
        renderGame();
        setTimeout(() => {
          const fails = GS.questCards.filter(c=>c==='fail').length;
          finalizeQuestResult(fails);
        }, 800);
        break;
      case 'LADY':
        botLadyAction();
        break;
      case 'ASSASSIN':
        botAssassinAction();
        break;
    }
  } catch(err) {
    showToast('Bot error: ' + err.message, 'error');
    console.error('[Bot]', err);
  }
}

function botNominate() {
  const leaderSeat = GS.currentLeader;
  const leaderRole = GS.roles[leaderSeat];
  const count = GS.players.length;
  const questSize = (GAME_TEXT_CONFIG.questSizes[count] || GAME_TEXT_CONFIG.questSizes[5])[GS.currentQuest];
  const isEvil = ['assassin','morgana','mordred','oberon','evil_generic'].includes(leaderRole);

  let team = [];
  // Always include leader
  team.push(leaderSeat);

  const failedPlayers = new Set();
  GS.gameLog.forEach(log => {
    if (log.includes('FAIL')) {
      GS.nominatedSeats.forEach(s => failedPlayers.add(s));
    }
  });

  if (isEvil) {
    // Try to include one evil ally
    const allies = GS.players.map((_,i) => i)
      .filter(i => i !== leaderSeat && ['assassin','morgana','mordred','evil_generic'].includes(GS.roles[i]));
    const goodBuffers = GS.players.map((_,i) => i)
      .filter(i => i !== leaderSeat && !['assassin','morgana','mordred','oberon','evil_generic'].includes(GS.roles[i]));

    // Prioritize mordred
    const mordredSeat = GS.players.findIndex((_,i) => GS.roles[i] === 'mordred' && i !== leaderSeat);
    if (mordredSeat > -1 && team.length < questSize) team.push(mordredSeat);

    // Add one more evil
    for (const a of allies) {
      if (!team.includes(a) && team.length < questSize) { team.push(a); break; }
    }
    // Fill with good buffers
    shuffleArray(goodBuffers);
    for (const g of goodBuffers) {
      if (!team.includes(g) && team.length < questSize) team.push(g);
    }
  } else {
    // Good leader: include non-failed players
    const safePlayers = GS.players.map((_,i) => i)
      .filter(i => i !== leaderSeat && !failedPlayers.has(i));
    shuffleArray(safePlayers);
    for (const s of safePlayers) {
      if (team.length >= questSize) break;
      team.push(s);
    }
    // If not enough, fill from all
    const all = GS.players.map((_,i) => i).filter(i => !team.includes(i));
    shuffleArray(all);
    for (const s of all) {
      if (team.length >= questSize) break;
      team.push(s);
    }
  }

  GS.nominatedSeats = team.slice(0, questSize);
  GS.demoPerspective = leaderSeat;
  updateDemoPerspectiveDropdown();
  submitNomination();
}

function botVoteAll() {
  GS.players.forEach((_, i) => {
    if (GS.teamVotes[i] !== undefined) return;
    const role = GS.roles[i];
    const isEvil = ['assassin','morgana','mordred','oberon','evil_generic'].includes(role);
    const teamHasAlly = GS.nominatedSeats.some(s => ['assassin','morgana','mordred','evil_generic'].includes(GS.roles[s]) && s !== i);

    let vote;
    if (isEvil) {
      vote = teamHasAlly ? 'approve' : (Math.random() < 0.3 ? 'approve' : 'reject');
    } else {
      // Good: approve if on team or hammer
      const onTeam = GS.nominatedSeats.includes(i);
      const isHammer = GS.voteTracker >= 4;
      const hasSuspect = GS.nominatedSeats.some(s => ['assassin','morgana','evil_generic'].includes(GS.roles[s]));
      vote = (onTeam || isHammer || !hasSuspect) ? 'approve' : 'reject';
    }
    GS.teamVotes[i] = vote;
  });
  setTimeout(resolveTeamVote, 600);
  renderGame();
}

function botQuestCardsAll() {
  const evilOnTeam = GS.nominatedSeats.filter(s => ['assassin','morgana','mordred','oberon','evil_generic'].includes(GS.roles[s]));

  GS.nominatedSeats.forEach((seat, idx) => {
    if (GS.questCards.length > idx) return;
    const role = GS.roles[seat];
    const isEvil = ['assassin','morgana','mordred','oberon','evil_generic'].includes(role);
    let card;
    if (isEvil) {
      // Only highest-index evil drops the fail
      const evilIndexes = evilOnTeam.sort((a,b) => a-b);
      card = seat === evilIndexes[evilIndexes.length - 1] ? 'fail' : 'success';
    } else {
      card = 'success';
    }
    GS.questCards.push(card);
  });
  shuffleArray(GS.questCards);
  GS.myQuestCard = GS.questCards[0];
  GS.phase = 'REVEAL';
  GS.revealedCards = [];
  renderGame();
}

function botLadyAction() {
  const eligible = GS.players.map((_,i)=>i).filter(i => !GS.ladyHistory.includes(i) && i !== GS.ladyHolder);
  if (eligible.length === 0) { advanceQuest(); return; }
  GS.assassinTarget = eligible[Math.floor(Math.random()*eligible.length)];
  renderGame();
  setTimeout(confirmLadyInvestigation, 800);
}

function botAssassinAction() {
  // AI: find highest Merlin score
  // Discount players who approved failed quests (they're probably evil)
  const failedQuestApprovers = new Set();
  // Simple heuristic: pick non-evil-known player with most quest approvals
  const candidates = GS.players.map((_,i)=>i).filter(i => {
    const r = GS.roles[i];
    return !['assassin','morgana','mordred','oberon','evil_generic'].includes(r);
  });
  // Shuffle and pick — in real game, assassin uses deduction
  // Bot assassin picks the player who was on the most SUCCESSFUL quests
  let bestScore = -1, bestSeat = candidates[0] || 1;
  candidates.forEach(seat => {
    const score = Math.random(); // Simplified probability
    if (score > bestScore) { bestScore = score; bestSeat = seat; }
  });
  GS.assassinTarget = bestSeat;
  renderGame();
  setTimeout(confirmAssassination, 1200);
}

// ══════════════════════════════════════════════════════
//  UTILITY FUNCTIONS
// ══════════════════════════════════════════════════════
function shuffleArray(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

// ══════════════════════════════════════════════════════
//  BOOTSTRAP
// ══════════════════════════════════════════════════════
// If PWA gate is not shown (already installed), trigger init
window.addEventListener('appinstalled', () => {
  deferredPrompt = null;
  hidePwaGate();
});

// Handle local room discovery (network scan simulation)
setTimeout(() => {
  const list = document.getElementById('localRoomsList');
  if (list) {
    list.innerHTML = `<p class="text-parchment/30 font-inter text-xs">No local rooms found. Ask your host for a code.</p>`;
  }
}, 2000);

// Async Firebase asset hot-swap
async function loadFirebaseAssets() {
  if (!GS.db) return;
  try {
    const snap = await GS.db.ref('assets').once('value');
    if (!snap.exists()) return;
    const data = snap.val();
    Object.entries(data).forEach(([key, val]) => {
      const path = key.replace('_', '/') + '.png';
      localStorage.setItem(`asset_${path}`, val);
    });
  } catch(err) {
    console.warn('[Assets] Firebase load failed:', err);
  }
}
</script>
