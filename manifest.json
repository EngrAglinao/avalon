  });
}

// ══════════════════════════════════════════════════════
//  FIREBASE INIT
// ══════════════════════════════════════════════════════
function initFirebase() {
  try {
    if (!firebaseConfig.apiKey) {
      console.warn('[Firebase] No config provided — running in offline/demo mode.');
      return false;
    }
    if (!firebase.apps.length) firebase.initializeApp(firebaseConfig);
    GS.fb = firebase;
    GS.auth = firebase.auth();
    GS.db = firebase.database();
    return true;
  } catch (err) {
    console.error('[Firebase] Init error:', err);
    showToast('Firebase not configured. Guest mode only.', 'warn');
    return false;
  }
}

// ══════════════════════════════════════════════════════
//  TOAST SYSTEM
// ══════════════════════════════════════════════════════
function showToast(msg, type = 'info', duration = 3200) {
  const container = document.getElementById('toastContainer');
  if (!container) return;
  const t = document.createElement('div');
  t.className = `toast ${type}`;
  t.textContent = msg;
  container.appendChild(t);
  setTimeout(() => { try { container.removeChild(t); } catch(e){} }, duration);
}

