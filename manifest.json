    function closeQrScanner() {
      appState.qrScannerOpen = false;
      if (appState.qrScanLoop) {
        cancelAnimationFrame(appState.qrScanLoop);
        appState.qrScanLoop = null;
      }
      if (appState.qrStream) {
        appState.qrStream.getTracks().forEach((t) => t.stop());
        appState.qrStream = null;
      }
      renderOverlays();
    }

    async function openQrScanner() {
      if (!window.BarcodeDetector) return toast("QR scanner is not supported on this browser.");
      if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) return toast("Camera API unavailable.");
      appState.qrScannerOpen = true;
      renderOverlays();
      const video = document.getElementById("qrVideo");
      if (!video) return;
      try {
        appState.qrStream = await navigator.mediaDevices.getUserMedia({
          video: { facingMode: { ideal: "environment" } },
          audio: false
        });
        video.srcObject = appState.qrStream;
        await video.play();
      } catch (_err) {
        toast("Camera permission denied.");
        return closeQrScanner();
      }

      const detector = new BarcodeDetector({ formats: ["qr_code"] });
      const tick = async () => {
        if (!appState.qrScannerOpen) return;
        try {
          const found = await detector.detect(video);
          if (found.length) {
            const raw = found[0].rawValue || "";
            let code = raw.trim();
            try {
              const url = new URL(raw);
              code = url.searchParams.get("room") || code;
            } catch (_err) {}
            if (code) {
              closeQrScanner();
              joinRoomByCode(code);
              return;
            }
          }
        } catch (_err) {}
        appState.qrScanLoop = requestAnimationFrame(tick);
      };
      tick();
    }

